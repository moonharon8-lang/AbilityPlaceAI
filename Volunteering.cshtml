    icon_emoji: '📚', icon_bg: 'var(--lav)',
    urgency: 'open',
    mode: 'both',
    commitment: '2–4 hrs/week',
    spots_total: 15, spots_taken: 7,
    skills: ['Teaching', 'Patience', 'Curriculum'],
