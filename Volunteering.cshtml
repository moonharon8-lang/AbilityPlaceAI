        <a class="mobile-menu-link" href="/Home/Signin" style="color:var(--peach-d);font-weight:600">Sign in</a>
        <a class="mobile-menu-link" href="/Home/Signup" style="background:var(--peach);border-radius:14px;font-weight:700;text-align:center">Get started →</a>
</div>

<!-- ══════ PAGE HERO ══════ -->
<div class="page-hero">
  <div class="page-hero-birds"></div>
  <div class="page-hero-content">
    <div class="eyebrow">🤝 Give back</div>
    <h1>Volunteer with Us</h1>
    <p>Join our community of volunteers making a real difference in the lives of people with disabilities — one session, one lesson, one smile at a time.</p>
  </div>
  <div class="page-hero-wave">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%;display:block">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="rgba(255,255,255,.5)"/>
      <path d="M0,45 C360,15 720,60 1080,35 C1260,22 1380,50 1440,45 L1440,60 L0,60 Z" fill="var(--ink)"/>
    </svg>
  </div>
</div>

<!-- ══════ IMPACT STRIP ══════ -->
<div class="impact-strip">
  <div class="impact-item">
    <span class="impact-n">340+</span>
    <div class="impact-l">Active volunteers</div>
  </div>
  <div class="impact-item">
    <span class="impact-n">12,000+</span>
    <div class="impact-l">Hours contributed</div>
  </div>
  <div class="impact-item">
    <span class="impact-n">1,800+</span>
    <div class="impact-l">Lives touched</div>
  </div>
  <div class="impact-item">
    <span class="impact-n">30+</span>
    <div class="impact-l">Open roles right now</div>
  </div>
</div>

<!-- ══════ MAIN ══════ -->
<div class="vol-page">
  <div class="vol-inner">

    <!-- ── WHY VOLUNTEER ── -->
    <div style="margin-bottom:52px" class="reveal">
      <div class="eyebrow">Why it matters</div>
      <div class="vol-section-title">What you'll gain</div>
      <div class="vol-section-sub">Volunteering with BridgeUp isn't just giving — it's growing too.</div>
    </div>

    <div class="why-grid">
      <div class="why-card reveal">
        <span class="why-icon">🎓</span>
        <h3>Certified Experience</h3>
        <p>Receive an official BridgeUp volunteer certificate recognized by our partner centers and universities.</p>
      </div>
      <div class="why-card reveal">
        <span class="why-icon">🌍</span>
        <h3>Real Impact</h3>
        <p>Work directly with individuals with disabilities and their families — your contribution is visible and meaningful.</p>
      </div>
      <div class="why-card reveal">
        <span class="why-icon">🤝</span>
        <h3>Community</h3>
        <p>Join a warm, driven community of educators, therapists, and change-makers who support each other.</p>
      </div>
      <div class="why-card reveal">
        <span class="why-icon">📈</span>
        <h3>Skill Building</h3>
        <p>Develop real skills in accessibility, communication, sign language, and inclusive education.</p>
      </div>
    </div>

    <!-- ── OPEN ROLES ── -->
    <div style="margin-bottom:28px">
      <div class="eyebrow reveal">Open positions</div>
      <div class="vol-section-title reveal">Find your role</div>
      <div class="vol-section-sub reveal">Browse open volunteer roles and click Apply to fill in your details below.</div>
    </div>

    <div class="roles-filter">
      <button class="rfchip active" onclick="filterRoles('', this)">All Roles</button>
      <button class="rfchip" onclick="filterRoles('remote', this)">🌐 Remote</button>
      <button class="rfchip" onclick="filterRoles('onsite', this)">📍 On-site</button>
      <button class="rfchip" onclick="filterRoles('urgent', this)">🔴 Urgent</button>
      <button class="rfchip" onclick="filterRoles('sign', this)">🤟 Sign Language</button>
      <button class="rfchip" onclick="filterRoles('teaching', this)">📚 Teaching</button>
    </div>

    <!--
      TODO: fetch from Supabase
      Table: volunteer_roles (id, title, description, icon_emoji, icon_bg,
                              urgency ['urgent'|'open'|'flexible'],
                              mode ['remote'|'onsite'|'both'],
                              commitment, spots_total, spots_taken,
                              skills text[], tags text[],
                              created_at timestamptz)
      Query: supabase.from('volunteer_roles').select('*').eq('is_active', true)
    -->
    <div class="roles-grid" id="rolesGrid"></div>

    <!-- ── APPLICATION FORM ── -->
    <div class="form-card" id="applicationForm">
      <div class="form-card-header">
        <h2>Apply to Volunteer 🙌</h2>
        <p>Fill in your details and we'll match you with the right opportunity within 2–3 business days.</p>
      </div>

      <div class="form-card-body" id="formBody">
        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Full Name <span class="required">*</span></label>
            <input class="form-input" type="text" id="v-name" placeholder="Your full name"/>
            <div class="field-error" id="err-name">Please enter your name.</div>
          </div>
          <div class="form-group">
            <label class="form-label">Email <span class="required">*</span></label>
            <input class="form-input" type="email" id="v-email" placeholder="you@example.com"/>
            <div class="field-error" id="err-email">Please enter a valid email.</div>
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label">Phone Number</label>
            <input class="form-input" type="tel" id="v-phone" placeholder="+20 10 0000 0000"/>
          </div>
          <div class="form-group">
            <label class="form-label">City <span class="required">*</span></label>
            <select class="form-input" id="v-city">
              <option value="">Select your city…</option>
              <option>Cairo</option>
              <option>Giza</option>
              <option>Alexandria</option>
              <option>Mansoura</option>
              <option>Assiut</option>
              <option>Other</option>
            </select>
            <div class="field-error" id="err-city">Please select your city.</div>
          </div>
        </div>

        <div class="form-group">
          <label class="form-label">Area of Interest <span class="required">*</span></label>
          <select class="form-input" id="v-role">
            <option value="">Select a role…</option>
            <option value="sign">🤟 Sign Language Interpreter</option>
            <option value="tutor">📚 Tutoring & Mentoring</option>
            <option value="event">🎪 Event Assistance</option>
            <option value="sensory">🌈 Sensory Room Support</option>
            <option value="content">✍️ Content Creation</option>
            <option value="tech">💻 Tech & Accessibility Support</option>
            <option value="admin">📋 Admin & Coordination</option>
          </select>
          <div class="field-error" id="err-role">Please select a role.</div>
        </div>

        <div class="form-group">
          <label class="form-label">Availability <span class="required">*</span></label>
          <div class="avail-grid" id="availGrid">
            <label class="avail-item" onclick="toggleAvail(this)">
              <input type="checkbox" value="weekday-morning"> Weekday mornings
            </label>
            <label class="avail-item" onclick="toggleAvail(this)">
              <input type="checkbox" value="weekday-afternoon"> Weekday afternoons
            </label>
            <label class="avail-item" onclick="toggleAvail(this)">
              <input type="checkbox" value="weekday-evening"> Weekday evenings
            </label>
            <label class="avail-item" onclick="toggleAvail(this)">
              <input type="checkbox" value="weekend-morning"> Weekend mornings
            </label>
            <label class="avail-item" onclick="toggleAvail(this)">
              <input type="checkbox" value="weekend-afternoon"> Weekend afternoons
            </label>
            <label class="avail-item" onclick="toggleAvail(this)">
              <input type="checkbox" value="remote-anytime"> Remote / flexible
            </label>
          </div>
          <div class="field-error" id="err-avail">Please select at least one availability slot.</div>
        </div>

        <div class="form-group">
          <label class="form-label">Relevant Experience or Skills</label>
          <textarea
            class="form-input"
            id="v-experience"
            rows="3"
            placeholder="e.g. I studied special education, I know basic sign language, I have experience tutoring children with ADHD…"
          ></textarea>
        </div>

        <div class="form-group">
          <label class="form-label">Why do you want to volunteer with BridgeUp? <span class="required">*</span></label>
          <textarea
            class="form-input"
            id="v-motivation"
            rows="4"
            placeholder="Tell us what motivates you and what you hope to contribute…"
          ></textarea>
          <div class="field-error" id="err-motivation">Please share your motivation.</div>
        </div>

        <div style="display:flex;align-items:flex-start;gap:10px;margin-bottom:8px;font-size:.84rem;color:var(--ink-3)">
          <input type="checkbox" id="v-tos" style="width:16px;height:16px;accent-color:var(--peach-d);margin-top:2px;flex-shrink:0"/>
          <label for="v-tos">I agree to BridgeUp's <a href="#" style="color:var(--peach-d);font-weight:700">Volunteer Terms</a> and understand that my application will be reviewed by the team.</label>
        </div>
        <div class="field-error" id="err-tos">Please accept the volunteer terms to continue.</div>
      </div>

      <div class="form-submit-area" id="formSubmitArea">
        <div class="form-note">
          🕐 We review all applications within 2–3 business days. You'll receive a confirmation email once reviewed.
        </div>
        <button class="btn-primary" onclick="submitApplication()" style="padding:14px 36px">
          Submit Application →
        </button>
      </div>

      <!-- Success state -->
      <div class="form-success" id="formSuccess">
        <div class="success-icon">🎉</div>
        <h3>Application submitted!</h3>
        <p>Thank you for wanting to make a difference. We'll review your application and be in touch within 2–3 business days.</p>
        <button class="btn-primary" onclick="resetForm()">Submit another application</button>
      </div>
    </div>

  </div>
</div>

