<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — Volunteering</title>
<link rel="stylesheet" href="~/css/global.css"/>
<style>

/* ══════════════════════════════════════
   PAGE HERO
══════════════════════════════════════ */
.page-hero {
  padding-top: var(--nav-h);
  background: var(--sky);
  position: relative;
  overflow: hidden;
  min-height: 280px;
  display: flex;
  align-items: flex-end;
}
.page-hero-birds {
  position: absolute;
  inset: 0;
            background-image: url('/image/ability6.png');
  background-size: 50%;
  background-repeat: no-repeat;
  background-position: right 5% center;
  opacity: .65;
  pointer-events: none;
}
.page-hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0; z-index: 2;
}
.page-hero-content {
  position: relative;
  z-index: 3;
  padding: 40px 60px 68px;
}
.page-hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  letter-spacing: -.025em;
  color: var(--ink);
  margin-bottom: 8px;
}
.page-hero-content p {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.7;
  max-width: 520px;
}

/* ══════════════════════════════════════
   IMPACT STRIP
══════════════════════════════════════ */
.impact-strip {
  background: var(--ink);
  padding: 32px 60px;
  display: flex;
  align-items: center;
  justify-content: space-around;
  gap: 20px;
  flex-wrap: wrap;
}
.impact-item { text-align: center; }
.impact-n {
  font-family: 'Playfair Display', serif;
  font-size: 2.2rem;
  font-weight: 900;
  color: var(--peach);
  display: block;
  line-height: 1;
}
.impact-l {
  font-size: .8rem;
  color: rgba(255,255,255,.5);
  margin-top: 6px;
  font-weight: 500;
}

/* ══════════════════════════════════════
   MAIN CONTENT
══════════════════════════════════════ */
.vol-page {
  background: var(--off-white);
  padding: 60px 60px 80px;
}
.vol-inner {
  max-width: 1100px;
  margin: 0 auto;
}

/* ══════════════════════════════════════
   SECTION HEADERS
══════════════════════════════════════ */
.vol-section-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.7rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 6px;
  letter-spacing: -.02em;
}
.vol-section-sub {
  font-size: .9rem;
  color: var(--ink-4);
  margin-bottom: 28px;
  line-height: 1.6;
}

/* ══════════════════════════════════════
   ROLES FILTER
══════════════════════════════════════ */
.roles-filter {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  margin-bottom: 28px;
}
.rfchip {
  padding: 8px 18px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: #fff;
  font-size: .82rem;
  font-weight: 600;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
  white-space: nowrap;
}
.rfchip:hover { border-color: var(--mint-d); color: var(--ink); }
.rfchip.active {
  background: var(--peach);
  border-color: var(--peach-d);
  color: var(--ink);
}

/* ══════════════════════════════════════
   ROLE CARDS
══════════════════════════════════════ */
.roles-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 72px;
}
.role-card {
  background: #fff;
  border-radius: var(--radius);
  border: 1.5px solid rgba(0,0,0,.07);
  overflow: hidden;
  transition: all .25s;
  display: flex;
  flex-direction: column;
}
.role-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}
.role-card-top {
  padding: 24px 22px 18px;
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.role-icon {
  width: 52px; height: 52px;
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem;
  flex-shrink: 0;
}
.role-card-info { flex: 1; }
.role-card-info h3 {
  font-weight: 700;
  font-size: .97rem;
  color: var(--ink);
  margin-bottom: 4px;
}
.role-badges {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 6px;
}
.urgency-badge {
  padding: 2px 9px;
  border-radius: var(--radius-pill);
  font-size: .68rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .04em;
}
.mode-badge {
  padding: 2px 9px;
  border-radius: var(--radius-pill);
  font-size: .68rem;
  font-weight: 600;
  background: var(--sky);
  color: var(--mint-dd);
}
.role-desc {
  font-size: .82rem;
  color: var(--ink-3);
  line-height: 1.65;
  padding: 0 22px 16px;
  flex: 1;
}
.role-details {
  padding: 0 22px 16px;
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  font-size: .76rem;
  color: var(--ink-4);
}
.role-details span { display: flex; align-items: center; gap: 4px; }
.role-skills {
  padding: 0 22px 18px;
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
}
.skill-tag {
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  background: var(--sky);
  font-size: .7rem;
  font-weight: 700;
  color: var(--mint-dd);
}
.role-footer {
  padding: 16px 22px;
  border-top: 1px solid rgba(0,0,0,.06);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}
.spots-left {
  font-size: .78rem;
  font-weight: 700;
  color: var(--ink-3);
}
.spots-left span { color: var(--peach-d); }
.apply-btn {
  padding: 9px 20px;
  border-radius: var(--radius-pill);
  border: none;
  background: var(--peach);
  color: var(--ink);
  font-weight: 700;
  font-size: .82rem;
  cursor: pointer;
  transition: all .2s;
}
.apply-btn:hover { background: var(--peach-d); color: #fff; }
.apply-btn:disabled {
  background: #E2E8F0;
  color: var(--ink-5);
  cursor: not-allowed;
}

/* ══════════════════════════════════════
   WHY VOLUNTEER SECTION
══════════════════════════════════════ */
.why-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 72px;
}
.why-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 28px 22px;
  box-shadow: var(--shadow);
  text-align: center;
}
.why-icon { font-size: 2.2rem; margin-bottom: 14px; display: block; }
.why-card h3 { font-weight: 700; font-size: .95rem; margin-bottom: 8px; }
.why-card p { font-size: .82rem; color: var(--ink-4); line-height: 1.65; }

/* ══════════════════════════════════════
   APPLICATION FORM
══════════════════════════════════════ */
.form-card {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.form-card-header {
  background: linear-gradient(135deg, var(--lav) 0%, var(--peach) 100%);
  padding: 32px 36px;
}
.form-card-header h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 900;
  margin-bottom: 6px;
}
.form-card-header p {
  font-size: .88rem;
  color: var(--ink-3);
  line-height: 1.6;
}
.form-card-body {
  padding: 36px;
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.form-group { margin-bottom: 20px; }
.form-label {
  display: block;
  font-size: .82rem;
  font-weight: 600;
  color: var(--ink-3);
  margin-bottom: 7px;
  letter-spacing: .01em;
}
.form-label .required { color: var(--peach-d); margin-left: 2px; }

/* Availability checkboxes */
.avail-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}
.avail-item {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 12px;
  border-radius: var(--radius-sm);
  border: 1.5px solid #E2E8F0;
  cursor: pointer;
  transition: all .2s;
  font-size: .82rem;
  font-weight: 500;
  color: var(--ink-3);
}
.avail-item:hover { border-color: var(--mint-d); }
.avail-item input[type="checkbox"] {
  accent-color: var(--peach-d);
  width: 16px; height: 16px;
}
.avail-item.checked {
  border-color: var(--peach-d);
  background: #fff8f6;
  color: var(--ink);
}

/* Form submit area */
.form-submit-area {
  padding: 0 36px 36px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}
.form-note {
  font-size: .8rem;
  color: var(--ink-4);
  max-width: 360px;
  line-height: 1.6;
}

/* Error + success */
.field-error {
  font-size: .76rem;
  color: #E53E3E;
  margin-top: 5px;
  display: none;
}
.field-error.show { display: block; }
.input-error {
  border-color: #FC8181 !important;
}

/* Success state */
.form-success {
  display: none;
  text-align: center;
  padding: 60px 36px;
  animation: popIn .4s cubic-bezier(.175,.885,.32,1.275);
}
.form-success.show { display: block; }
@@keyframes popIn {
  from { transform: scale(.92); opacity: 0; }
  to   { transform: scale(1);   opacity: 1; }
}
.success-icon { font-size: 3.5rem; margin-bottom: 16px; }
.form-success h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 900;
  margin-bottom: 10px;
}
.form-success p {
  font-size: .9rem;
  color: var(--ink-3);
  margin-bottom: 28px;
  line-height: 1.7;
  max-width: 400px;
  margin-left: auto;
  margin-right: auto;
}

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@@media (max-width: 1100px) {
  .roles-grid { grid-template-columns: repeat(2, 1fr); }
  .why-grid   { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 900px) {
  .vol-page         { padding: 48px 24px 60px; }
  .impact-strip     { padding: 28px 32px; }
  .page-hero-content{ padding: 36px 24px 60px; }
  .form-row         { grid-template-columns: 1fr; }
  .form-card-body   { padding: 24px; }
  .form-submit-area { padding: 0 24px 24px; }
  .form-card-header { padding: 24px; }
}
@@media (max-width: 600px) {
  .roles-grid   { grid-template-columns: 1fr; }
  .why-grid     { grid-template-columns: 1fr 1fr; }
  .avail-grid   { grid-template-columns: 1fr 1fr; }
  .form-submit-area { flex-direction: column; align-items: stretch; }
}
</style>
</head>
<body>

