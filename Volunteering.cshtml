    mode: 'onsite',
    commitment: 'Event-based',
    spots_total: 20, spots_taken: 11,
    skills: ['Organization', 'Communication', 'Energy'],
    tags: ['onsite'],
  },
  {
    id: 'r4',
    title: 'Sensory Room Support',
    description: 'Assist certified therapists during sensory integration sessions at partner centers. Work directly with children and adults in a therapeutic environment.',
    icon_emoji: '🌈', icon_bg: '#DCEDC8',
    urgency: 'urgent',
    mode: 'onsite',
    commitment: '3–5 hrs/week',
    spots_total: 6, spots_taken: 4,
    skills: ['Empathy', 'Calm presence', 'Therapy basics'],
    tags: ['onsite'],
  },
  {
    id: 'r5',
    title: 'Content Creator',
    description: 'Create accessible educational content — subtitles, simplified text summaries, visual aids, illustrations, and video scripts for our courses and classes.',
    icon_emoji: '✍️', icon_bg: '#E8EAF6',
    urgency: 'open',
    mode: 'remote',
    commitment: '3–6 hrs/week',
    spots_total: 10, spots_taken: 3,
    skills: ['Writing', 'Design', 'Accessibility'],
    tags: ['remote', 'teaching'],
  },
  {
    id: 'r6',
    title: 'Tech & Accessibility Support',
    description: 'Help test our platform for accessibility, assist learners with screen readers and assistive tech, and support the team with technical issues.',
    icon_emoji: '💻', icon_bg: '#FFF9C4',
    urgency: 'open',
    mode: 'remote',
    commitment: '2–4 hrs/week',
    spots_total: 8, spots_taken: 2,
    skills: ['Tech-savvy', 'Accessibility', 'Troubleshooting'],
    tags: ['remote'],
  },
]

const URGENCY_CONFIG = {
  urgent:   { label: '🔴 Urgent',   bg: '#FFCDD2', color: '#B71C1C' },
  open:     { label: '✅ Open',     bg: '#C8E6C9', color: '#1B5E20' },
  flexible: { label: '🟡 Flexible', bg: '#FFF9C4', color: '#F57F17' },
}
const MODE_LABELS = { remote: '🌐 Remote', onsite: '📍 On-site', both: '🔄 Both' }

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
let activeRoleFilter = ''
let selectedRoleId   = null

// ══════════════════════════════════════
// NAV
// ══════════════════════════════════════
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10)
})
function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('open')
}
document.querySelectorAll('.mobile-menu-link').forEach(l => {
  l.addEventListener('click', () => document.getElementById('mobileMenu').classList.remove('open'))
})

// ══════════════════════════════════════
// ROLES RENDER
// ══════════════════════════════════════
function filterRoles(filter, btn) {
  activeRoleFilter = filter
  document.querySelectorAll('.rfchip').forEach(c => c.classList.remove('active'))
  btn.classList.add('active')
  renderRoles()
}

function renderRoles() {
  const grid = document.getElementById('rolesGrid')
  let list = [...ROLES_DATA]
  if (activeRoleFilter) {
    list = list.filter(r => r.tags.includes(activeRoleFilter))
  }

  if (!list.length) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--ink-4)">
      <div style="font-size:2rem;margin-bottom:12px">🤝</div>
      <p>No roles match this filter right now. Check back soon!</p>
    </div>`
    return
  }

  grid.innerHTML = list.map(r => {
    const urg = URGENCY_CONFIG[r.urgency]
    const spotsLeft = r.spots_total - r.spots_taken
    const isFull = spotsLeft <= 0

    return `
      <div class="role-card reveal">
        <div class="role-card-top">
          <div class="role-icon" style="background:${r.icon_bg}">${r.icon_emoji}</div>
          <div class="role-card-info">
            <h3>${r.title}</h3>
            <div class="role-badges">
              <span class="urgency-badge" style="background:${urg.bg};color:${urg.color}">${urg.label}</span>
              <span class="mode-badge">${MODE_LABELS[r.mode]}</span>
            </div>
          </div>
        </div>
        <p class="role-desc">${r.description}</p>
        <div class="role-details">
          <span>⏱ ${r.commitment}</span>
          <span>👥 ${spotsLeft} spot${spotsLeft !== 1 ? 's' : ''} left</span>
        </div>
        <div class="role-skills">
          ${r.skills.map(s => `<span class="skill-tag">${s}</span>`).join('')}
        </div>
        <div class="role-footer">
          <div class="spots-left">
            <span>${r.spots_taken}</span> / ${r.spots_total} spots filled
          </div>
          <button
            class="apply-btn"
            ${isFull ? 'disabled' : ''}
            onclick="prefillRole('${r.id}', '${r.title.replace(/'/g,"\\'")}')">
            ${isFull ? 'Full' : 'Apply →'}
          </button>
        </div>
      </div>`
  }).join('')

  grid.querySelectorAll('.reveal').forEach((el, i) => {
    el.style.transitionDelay = (i * 60) + 'ms'
    revealObserver.observe(el)
  })
}

// ══════════════════════════════════════
// PREFILL FORM FROM ROLE CARD
// ══════════════════════════════════════
function prefillRole(id, title) {
  selectedRoleId = id
  // Map role id to select option value
  const roleMap = {
    r1: 'sign', r2: 'tutor', r3: 'event',
    r4: 'sensory', r5: 'content', r6: 'tech',
  }
  const roleSelect = document.getElementById('v-role')
  if (roleMap[id]) roleSelect.value = roleMap[id]

  // Smooth scroll to form
  document.getElementById('applicationForm').scrollIntoView({ behavior: 'smooth', block: 'start' })
  showToast(`✅ Role pre-filled: ${title}`)
}

// ══════════════════════════════════════
// AVAILABILITY CHECKBOXES
// ══════════════════════════════════════
function toggleAvail(label) {
  const cb = label.querySelector('input[type="checkbox"]')
  // Let the browser handle check state, just update styling
  setTimeout(() => {
    label.classList.toggle('checked', cb.checked)
  }, 0)
}

// ══════════════════════════════════════
// FORM VALIDATION & SUBMIT
// ══════════════════════════════════════
function submitApplication() {
  if (!validateForm()) return

  const payload = {
    name:       document.getElementById('v-name').value.trim(),
    email:      document.getElementById('v-email').value.trim(),
    phone:      document.getElementById('v-phone').value.trim(),
    city:       document.getElementById('v-city').value,
    role:       document.getElementById('v-role').value,
    experience: document.getElementById('v-experience').value.trim(),
    motivation: document.getElementById('v-motivation').value.trim(),
    availability: [...document.querySelectorAll('#availGrid input:checked')].map(cb => cb.value),
  }

  // ── TODO: insert into Supabase ──────────────────────────
  // const { error } = await supabase.from('volunteer_applications').insert({
  //   ...payload,
  //   status: 'pending',
  //   created_at: new Date().toISOString(),
  // })
  // if (error) { showToast('❌ ' + error.message); return }
  // ── END TODO ─────────────────────────────────────────────

  // Show success
  document.getElementById('formBody').style.display        = 'none'
  document.getElementById('formSubmitArea').style.display  = 'none'
  document.getElementById('formSuccess').classList.add('show')
}

function validateForm() {
  let valid = true
  clearErrors()

  const name  = document.getElementById('v-name').value.trim()
  const email = document.getElementById('v-email').value.trim()
  const city  = document.getElementById('v-city').value
  const role  = document.getElementById('v-role').value
  const motiv = document.getElementById('v-motivation').value.trim()
  const avail = document.querySelectorAll('#availGrid input:checked').length
  const tos   = document.getElementById('v-tos').checked

  if (!name)              { showErr('err-name', 'v-name');       valid = false }
  if (!email.includes('@@')){ showErr('err-email', 'v-email');    valid = false }
  if (!city)              { showErr('err-city', 'v-city');       valid = false }
  if (!role)              { showErr('err-role', 'v-role');       valid = false }
  if (!motiv)             { showErr('err-motivation', 'v-motivation'); valid = false }
  if (avail === 0)        { showErr('err-avail');                valid = false }
  if (!tos)               { showErr('err-tos');                  valid = false }

  return valid
}

function showErr(errId, inputId) {
  document.getElementById(errId).classList.add('show')
  if (inputId) document.getElementById(inputId).classList.add('input-error')
}
function clearErrors() {
  document.querySelectorAll('.field-error').forEach(e => e.classList.remove('show'))
  document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'))
}

function resetForm() {
  document.getElementById('formBody').style.display       = 'block'
  document.getElementById('formSubmitArea').style.display = 'flex'
  document.getElementById('formSuccess').classList.remove('show')
  document.getElementById('v-name').value        = ''
  document.getElementById('v-email').value       = ''
  document.getElementById('v-phone').value       = ''
  document.getElementById('v-city').value        = ''
  document.getElementById('v-role').value        = ''
  document.getElementById('v-experience').value  = ''
  document.getElementById('v-motivation').value  = ''
  document.getElementById('v-tos').checked       = false
  document.querySelectorAll('#availGrid input').forEach(cb => { cb.checked = false })
  document.querySelectorAll('.avail-item').forEach(l => l.classList.remove('checked'))
  clearErrors()
}

// ══════════════════════════════════════
// HELPERS
// ══════════════════════════════════════
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return
    entry.target.classList.add('visible')
  })
}, { threshold: 0.08 })

document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el))

function showToast(msg) {
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 2800)
}

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
renderRoles()
</script>
