<script>

// ══════════════════════════════════════
// PLACEHOLDER DATA
// TODO: fetch from Supabase volunteer_roles table
// ══════════════════════════════════════
const ROLES_DATA = [
  {
    id: 'r1',
    title: 'Sign Language Interpreter',
    description: 'Assist during live classes, community events, and one-on-one sessions as an ESL or ASL interpreter. Training and certification support provided.',
    icon_emoji: '🤟', icon_bg: 'var(--sky)',
    urgency: 'urgent',
    mode: 'onsite',
