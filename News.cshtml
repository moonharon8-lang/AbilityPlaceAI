    <!-- Featured -->
    <div id="featuredWrap"></div>

    <!-- Articles -->
    <div class="section-label" id="articlesLabel">Latest Articles</div>
    <!--
      TODO: fetch from Supabase
      Table: articles (id, title, excerpt, content, category, emoji,
                       thumb_color, type ['article'|'announcement'|'story'],
                       author, read_time_min int, published_at timestamptz,
                       is_featured bool)
      Query: supabase.from('articles').select('*')
               .order('published_at', { ascending: false })
    -->
    <div class="news-grid" id="newsGrid">
      <div class="news-skeleton"></div>
      <div class="news-skeleton"></div>
      <div class="news-skeleton"></div>
      <div class="news-skeleton"></div>
      <div class="news-skeleton"></div>
      <div class="news-skeleton"></div>
