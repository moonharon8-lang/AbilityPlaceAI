    <!--
      TODO: fetch from Supabase
      Table: events (id, title, description, icon_emoji, date, month_label,
                     location, mode ['online'|'in-person'|'hybrid'],
                     seats int, is_free bool, registration_url)
      Query: supabase.from('events').select('*')
               .gte('date', today).order('date', { ascending: true })
    -->
    <div class="events-list" id="eventsList"></div>

    <!-- Newsletter -->
    <div class="newsletter-banner reveal">
