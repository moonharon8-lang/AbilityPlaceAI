    <h1>News & Events</h1>
    <p>The latest research, community stories, platform updates, and upcoming events in inclusive education and disability support.</p>
  </div>
  <div class="page-hero-wave">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%;display:block">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="rgba(255,255,255,.5)"/>
      <path d="M0,45 C360,15 720,60 1080,35 C1260,22 1380,50 1440,45 L1440,60 L0,60 Z" fill="var(--off-white)"/>
    </svg>
  </div>
</div>

<!-- ══════ TOOLBAR ══════ -->
<div class="toolbar">
  <div class="search-wrap">
    <span class="search-icon">🔍</span>
    <input
      class="search-input"
      type="text"
      id="searchInput"
      placeholder="Search articles…"
      oninput="handleSearch(this.value)"
    />
  </div>
  <div class="cat-chips">
    <button class="cchip active" data-cat="" onclick="setFilter('', this)">All</button>
    <button class="cchip" data-cat="research"  onclick="setFilter('research', this)">🔬 Research</button>
    <button class="cchip" data-cat="community" onclick="setFilter('community', this)">🤝 Community</button>
    <button class="cchip" data-cat="platform"  onclick="setFilter('platform', this)">⚡ Platform</button>
    <button class="cchip" data-cat="awards"    onclick="setFilter('awards', this)">🏆 Awards</button>
    <button class="cchip" data-cat="events"    onclick="setFilter('events', this)">🗓 Events</button>
  </div>
  <span class="toolbar-count" id="toolbarCount"></span>
</div>

<!-- ══════ MAIN ══════ -->
<div class="news-layout">
