const CAT_LABELS = {
  research: 'Research', community: 'Community',
  platform: 'Platform Update', awards: 'Awards', events: 'Events',
}
const TYPE_COLORS = {
  article:      { bg: 'rgba(255,255,255,.85)', color: 'var(--lav-d)' },
  announcement: { bg: 'rgba(255,204,188,.85)', color: '#7B3F00' },
  story:        { bg: 'rgba(178,223,219,.85)', color: '#00695C' },
}

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
let activeFilter = ''
let searchQuery  = ''

// ══════════════════════════════════════
// NAV
// ══════════════════════════════════════
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10)
})
function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('open')
}
document.querySelectorAll('.mobile-menu-link').forEach(l => {
  l.addEventListener('click', () => document.getElementById('mobileMenu').classList.remove('open'))
})

// ══════════════════════════════════════
// FILTER & SEARCH
// ══════════════════════════════════════
function setFilter(cat, btn) {
  activeFilter = cat
  document.querySelectorAll('.cchip').forEach(c => c.classList.remove('active'))
  btn.classList.add('active')
  renderAll()
}

let searchTimer = null
function handleSearch(val) {
  clearTimeout(searchTimer)
  searchTimer = setTimeout(() => {
    searchQuery = val.trim().toLowerCase()
    renderAll()
  }, 220)
}

// ══════════════════════════════════════
// RENDER
// ══════════════════════════════════════
function renderAll() {
  let list = [...ARTICLES]
  if (activeFilter) list = list.filter(a => a.category === activeFilter)
  if (searchQuery)  list = list.filter(a =>
    a.title.toLowerCase().includes(searchQuery) ||
    a.excerpt.toLowerCase().includes(searchQuery)
  )

  document.getElementById('toolbarCount').textContent =
    `${list.length} article${list.length !== 1 ? 's' : ''}`

  // Featured (only show when no filter/search active)
  const featuredWrap = document.getElementById('featuredWrap')
  const featured = ARTICLES.find(a => a.is_featured)
  if (!activeFilter && !searchQuery && featured) {
    featuredWrap.innerHTML = renderFeatured(featured)
  } else {
    featuredWrap.innerHTML = ''
  }

  // Articles grid (exclude featured when no filter)
  const showList = (!activeFilter && !searchQuery)
    ? list.filter(a => !a.is_featured)
    : list

  const grid  = document.getElementById('newsGrid')
  const label = document.getElementById('articlesLabel')
  label.style.display = showList.length ? 'flex' : 'none'

  if (!showList.length) {
    grid.innerHTML = `<div class="empty-state">
      <div class="empty-icon">📰</div>
      <h3>No articles found</h3>
      <p>Try a different search or filter.</p>
    </div>`
    return
  }

  grid.innerHTML = showList.map(a => renderCard(a)).join('')
  grid.querySelectorAll('.reveal').forEach((el, i) => {
    el.style.transitionDelay = (i * 60) + 'ms'
    revealObserver.observe(el)
  })
}

function renderFeatured(a) {
  return `
    <div class="featured-card reveal" onclick="openArticle('${a.id}')">
      <div class="featured-thumb" style="background:${a.thumb_color}">
        ${a.emoji}
        <span class="featured-banner-label">✨ Featured</span>
      </div>
      <div class="featured-body">
        <div class="featured-cat">${CAT_LABELS[a.category] || a.category}</div>
        <h2>${a.title}</h2>
        <p>${a.excerpt}</p>
        <div class="featured-meta">
          <span>✍️ ${a.author}</span>
          <span>⏱ ${a.read_time_min} min read</span>
          <span>📅 ${formatDate(a.published_at)}</span>
        </div>
      </div>
    </div>`
}

function renderCard(a) {
  const typeStyle = TYPE_COLORS[a.type] || TYPE_COLORS.article
  return `
    <div class="news-card reveal" onclick="openArticle('${a.id}')">
      <div class="news-thumb" style="background:${a.thumb_color}">
        ${a.emoji}
        <span class="news-type-badge" style="background:${typeStyle.bg};color:${typeStyle.color}">
          ${a.type.charAt(0).toUpperCase() + a.type.slice(1)}
        </span>
      </div>
      <div class="news-body">
        <div class="news-cat">${CAT_LABELS[a.category] || a.category}</div>
        <h3>${a.title}</h3>
        <p>${a.excerpt}</p>
        <div class="news-footer">
          <span>${formatDate(a.published_at)} · ${a.read_time_min} min</span>
          <span class="news-read-more">Read more →</span>
        </div>
      </div>
    </div>`
}

function renderEvents() {
  const list = document.getElementById('eventsList')
  const label = document.getElementById('eventsLabel')
  if (!EVENTS.length) { label.style.display = 'none'; return; }

  list.innerHTML = EVENTS.map(ev => `
    <div class="event-card reveal">
      <div class="event-date-box">
        <span class="event-month">${ev.month_label}</span>
        <span class="event-day">${ev.day}</span>
      </div>
      <div class="event-icon">${ev.icon_emoji}</div>
      <div class="event-info">
        <h3>${ev.title}</h3>
        <p>${ev.description}</p>
        <div class="event-meta">
          <span>📍 ${ev.location}</span>
          <span>🌐 ${ev.mode.charAt(0).toUpperCase() + ev.mode.slice(1)}</span>
          <span>👥 ${ev.seats} seats</span>
          <span>${ev.is_free ? '🆓 Free' : '💎 Paid'}</span>
        </div>
      </div>
      <button class="event-register" onclick="registerEvent('${ev.id}', '${ev.title.replace(/'/g,"\\'")}')">
        ${ev.is_free ? 'Register Free' : 'Get Tickets'}
      </button>
    </div>`).join('')

  list.querySelectorAll('.reveal').forEach((el, i) => {
    el.style.transitionDelay = (i * 70) + 'ms'
    revealObserver.observe(el)
  })
}

// ══════════════════════════════════════
// ACTIONS
// ══════════════════════════════════════
function openArticle(id) {
  // TODO: navigate to article detail page or open modal
  const article = ARTICLES.find(a => a.id === id)
  if (article) showToast(`📰 Opening: "${article.title.slice(0, 40)}…"`)
}

function registerEvent(id, title) {
  // TODO: insert into event_registrations in Supabase
  showToast(`✅ Registered for "${title.slice(0, 35)}…"!`)
}

function subscribeNewsletter() {
  const email = document.getElementById('nlEmail').value.trim()
  if (!email || !email.includes('@@')) {
    showToast('⚠️ Please enter a valid email.')
    return
  }
  // TODO: insert into newsletter_subscribers in Supabase
  showToast('📬 Subscribed! Welcome to the loop.')
  document.getElementById('nlEmail').value = ''
}

// ══════════════════════════════════════
// HELPERS
// ══════════════════════════════════════
function formatDate(iso) {
  return new Date(iso).toLocaleDateString('en-EG', {
    year: 'numeric', month: 'short', day: 'numeric'
  })
}

const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return
    entry.target.classList.add('visible')
  })
}, { threshold: 0.08 })
document.querySelectorAll('.reveal').forEach(el => revealObserver.observe(el))

function showToast(msg) {
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 2800)
}

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
renderAll()
renderEvents()
</script>
