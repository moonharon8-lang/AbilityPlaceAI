<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — News & Events</title>
<link rel="stylesheet" href="/css/global.css"/>
<style>

/* ══════════════════════════════════════
   PAGE HERO
══════════════════════════════════════ */
.page-hero {
  padding-top: var(--nav-h);
  background: var(--sky);
  position: relative;
  overflow: hidden;
  min-height: 260px;
  display: flex;
  align-items: flex-end;
}
.page-hero-birds {
  position: absolute;
  inset: 0;
            background-image: url('/image/ability4.png');
  background-size: 50%;
  background-repeat: no-repeat;
  background-position: right 5% center;
  opacity: .6;
  pointer-events: none;
}
.page-hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0; z-index: 2;
}
.page-hero-content {
  position: relative;
  z-index: 3;
  padding: 40px 60px 68px;
}
.page-hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  letter-spacing: -.025em;
  color: var(--ink);
  margin-bottom: 8px;
}
.page-hero-content p {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.7;
  max-width: 500px;
}

/* ══════════════════════════════════════
   TOOLBAR
══════════════════════════════════════ */
.toolbar {
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,.07);
  position: sticky;
  top: var(--nav-h);
  z-index: 50;
  padding: 14px 60px;
  display: flex;
  align-items: center;
  gap: 12px;
  flex-wrap: wrap;
  box-shadow: 0 2px 12px rgba(0,0,0,.04);
}
.search-wrap {
  position: relative;
  min-width: 220px;
  max-width: 300px;
  flex: 1;
}
.search-icon {
  position: absolute;
  left: 13px; top: 50%;
  transform: translateY(-50%);
  font-size: .95rem;
  color: var(--ink-4);
  pointer-events: none;
}
.search-input {
  width: 100%;
  padding: 10px 14px 10px 38px;
  border: 1.5px solid #E2E8F0;
  border-radius: var(--radius-pill);
  font-size: .88rem;
  color: var(--ink);
  outline: none;
  background: var(--off-white);
  transition: all .2s;
}
.search-input:focus {
  border-color: var(--mint-d);
  box-shadow: 0 0 0 3px rgba(178,223,219,.3);
  background: #fff;
}
.cat-chips {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.cchip {
  padding: 8px 16px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: var(--off-white);
  font-size: .8rem;
  font-weight: 600;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
  white-space: nowrap;
}
.cchip:hover { border-color: var(--mint-d); color: var(--ink); }
.cchip.active {
  background: var(--peach);
  border-color: var(--peach-d);
  color: var(--ink);
}
.toolbar-count {
  margin-left: auto;
  font-size: .82rem;
  color: var(--ink-4);
  font-weight: 500;
  white-space: nowrap;
}

/* ══════════════════════════════════════
   MAIN LAYOUT
══════════════════════════════════════ */
.news-layout {
  padding: 48px 60px 80px;
  background: var(--off-white);
  min-height: 60vh;
}
.news-inner {
  max-width: 1100px;
  margin: 0 auto;
}

/* ══════════════════════════════════════
   FEATURED ARTICLE
══════════════════════════════════════ */
.featured-card {
  background: #fff;
  border-radius: var(--radius);
  overflow: hidden;
  box-shadow: var(--shadow-md);
  display: grid;
  grid-template-columns: 1fr 1fr;
  margin-bottom: 48px;
  cursor: pointer;
  transition: all .25s;
  border: 1.5px solid rgba(0,0,0,.06);
}
.featured-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}
.featured-thumb {
  min-height: 280px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 5rem;
  position: relative;
}
.featured-banner-label {
  position: absolute;
  top: 16px; left: 16px;
  padding: 6px 14px;
  border-radius: var(--radius-pill);
  background: var(--peach-d);
  color: #fff;
  font-size: .72rem;
  font-weight: 800;
  letter-spacing: .04em;
  text-transform: uppercase;
}
.featured-body {
  padding: 36px 32px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
.featured-cat {
  font-size: .72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--lav-d);
  margin-bottom: 10px;
}
.featured-body h2 {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 900;
  line-height: 1.25;
  color: var(--ink);
  margin-bottom: 14px;
  letter-spacing: -.02em;
}
.featured-body p {
  font-size: .9rem;
  color: var(--ink-3);
  line-height: 1.75;
  margin-bottom: 20px;
}
.featured-meta {
  display: flex;
  gap: 14px;
  font-size: .78rem;
  color: var(--ink-4);
  flex-wrap: wrap;
}
.featured-meta span { display: flex; align-items: center; gap: 4px; }

/* ══════════════════════════════════════
   NEWS GRID
══════════════════════════════════════ */
.section-label {
  font-size: .78rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .08em;
  color: var(--ink-4);
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.section-label::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(0,0,0,.08);
}

.news-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-bottom: 48px;
}
.news-card {
  background: #fff;
  border-radius: var(--radius);
  overflow: hidden;
  border: 1.5px solid rgba(0,0,0,.07);
  cursor: pointer;
  transition: all .25s;
  display: flex;
  flex-direction: column;
}
.news-card:hover {
  transform: translateY(-5px);
  box-shadow: var(--shadow-lg);
  border-color: transparent;
}
.news-thumb {
  height: 130px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 3rem;
  position: relative;
  flex-shrink: 0;
}
.news-type-badge {
  position: absolute;
  top: 10px; left: 10px;
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .03em;
  background: rgba(255,255,255,.88);
  backdrop-filter: blur(4px);
}
.news-body {
  padding: 18px;
  display: flex;
  flex-direction: column;
  flex: 1;
}
.news-cat {
  font-size: .68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--lav-d);
  margin-bottom: 6px;
}
.news-body h3 {
  font-weight: 700;
  font-size: .93rem;
  line-height: 1.4;
  margin-bottom: 8px;
  color: var(--ink);
  flex: 1;
}
.news-body p {
  font-size: .8rem;
  color: var(--ink-4);
  line-height: 1.6;
  margin-bottom: 14px;
}
.news-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: .74rem;
  color: var(--ink-5);
  border-top: 1px solid rgba(0,0,0,.06);
  padding-top: 12px;
  margin-top: auto;
}
.news-read-more {
  color: var(--peach-d);
  font-weight: 700;
  font-size: .75rem;
  cursor: pointer;
  transition: color .2s;
}
.news-read-more:hover { color: var(--peach-dd); }

/* ══════════════════════════════════════
   EVENTS SECTION
══════════════════════════════════════ */
.events-list {
  display: flex;
  flex-direction: column;
  gap: 14px;
  margin-bottom: 48px;
}
.event-card {
  background: #fff;
  border-radius: var(--radius);
  border: 1.5px solid rgba(0,0,0,.07);
  padding: 20px 24px;
  display: flex;
  align-items: center;
  gap: 20px;
  cursor: pointer;
  transition: all .2s;
}
.event-card:hover {
  border-color: var(--mint-d);
  transform: translateX(4px);
}
.event-date-box {
  width: 58px;
  flex-shrink: 0;
  text-align: center;
  background: var(--peach);
  border-radius: 14px;
  padding: 10px 8px;
}
.event-month {
  font-size: .65rem;
  font-weight: 800;
  text-transform: uppercase;
  letter-spacing: .06em;
  color: var(--peach-dd);
  display: block;
}
.event-day {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--ink);
  line-height: 1;
}
.event-icon { font-size: 1.8rem; flex-shrink: 0; }
.event-info { flex: 1; }
.event-info h3 { font-weight: 700; font-size: .95rem; margin-bottom: 4px; }
.event-info p  { font-size: .8rem; color: var(--ink-4); line-height: 1.5; }
.event-meta {
  display: flex;
  gap: 12px;
  flex-wrap: wrap;
  font-size: .75rem;
  color: var(--ink-4);
  margin-top: 6px;
}
.event-meta span { display: flex; align-items: center; gap: 3px; }
.event-register {
  padding: 9px 20px;
  border-radius: var(--radius-pill);
  border: none;
  background: var(--peach);
  color: var(--ink);
  font-weight: 700;
  font-size: .8rem;
  cursor: pointer;
  transition: all .2s;
  white-space: nowrap;
  flex-shrink: 0;
}
.event-register:hover { background: var(--peach-d); color: #fff; }

/* ══════════════════════════════════════
   NEWSLETTER BANNER
══════════════════════════════════════ */
.newsletter-banner {
  background: linear-gradient(135deg, var(--lav) 0%, var(--peach) 100%);
  border-radius: var(--radius);
  padding: 40px 48px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 28px;
  flex-wrap: wrap;
}
.nl-text h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  font-weight: 900;
  margin-bottom: 6px;
}
.nl-text p {
  font-size: .88rem;
  color: var(--ink-3);
  max-width: 360px;
  line-height: 1.6;
}
.nl-form {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
}
.nl-input {
  padding: 12px 20px;
  border-radius: var(--radius-pill);
  border: 2px solid rgba(255,255,255,.7);
  background: rgba(255,255,255,.8);
  font-family: 'DM Sans', sans-serif;
  font-size: .9rem;
  color: var(--ink);
  outline: none;
  width: 240px;
  transition: all .2s;
}
.nl-input:focus {
  background: #fff;
  border-color: var(--peach-d);
}
.nl-input::placeholder { color: var(--ink-4); }

/* Empty state */
.empty-state {
  text-align: center;
  padding: 80px 20px;
  color: var(--ink-4);
  grid-column: 1/-1;
}
.empty-icon { font-size: 3rem; margin-bottom: 16px; }
.empty-state h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.3rem;
  font-weight: 700;
  color: var(--ink-2);
  margin-bottom: 8px;
}

/* Skeleton */
.news-skeleton {
  border-radius: var(--radius);
  overflow: hidden;
  background: #fff;
  border: 1.5px solid rgba(0,0,0,.06);
  height: 300px;
}
.news-skeleton::before {
  content: '';
  display: block;
  height: 130px;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite;
}
.news-skeleton::after {
  content: '';
  display: block;
  height: 120px;
  margin: 18px;
  border-radius: 10px;
  background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.4s infinite .2s;
}
@@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@@media (max-width: 1100px) {
  .news-grid { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 900px) {
  .toolbar        { padding: 12px 24px; }
  .news-layout    { padding: 36px 24px 60px; }
  .page-hero-content { padding: 36px 24px 60px; }
  .featured-card  { grid-template-columns: 1fr; }
  .featured-thumb { min-height: 180px; }
  .newsletter-banner { flex-direction: column; }
  .nl-input { width: 100%; }
  .event-card { flex-wrap: wrap; }
  .event-register { width: 100%; text-align: center; }
}
@@media (max-width: 600px) {
  .news-grid { grid-template-columns: 1fr; }
}
</style>
</head>
