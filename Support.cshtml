      </div>

      <div class="chat-input-row">
        <input
          class="chat-input"
          type="text"
          id="chatInput"
          placeholder="Ask anything…"
          onkeydown="if(event.key==='Enter' && !event.shiftKey) sendMessage()"
          maxlength="500"
        />
        <button class="chat-send" id="sendBtn" onclick="sendMessage()" title="Send">➤</button>
      </div>
    </div>

    <!-- ══ SIDEBAR ══ -->
    <div class="sidebar">

      <!-- Quick links -->
      <div class="quick-links-card">
        <h3>💡 Quick Questions</h3>
        <button class="ql-btn" onclick="quickSend('How do I book a therapy session?')">📅 How to book a session?</button>
        <button class="ql-btn" onclick="quickSend('What courses do you have for autism?')">🧩 Courses for autism</button>
        <button class="ql-btn" onclick="quickSend('How does text to speech work?')">🔊 Text to Speech help</button>
