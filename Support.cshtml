<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — Support</title>
<link rel="stylesheet" href="~/css/global.css"/>
<style>


/* ══════════════════════════════════════
   PAGE HERO
══════════════════════════════════════ */
.page-hero {
  padding-top: var(--nav-h);
  background: var(--sky);
  position: relative;
  overflow: hidden;
  min-height: 220px;
  display: flex;
  align-items: flex-end;
}
.page-hero-birds {
  position: absolute;
  inset: 0;
            background-image: url('/image/ability5.png');
  background-size: 45%;
  background-repeat: no-repeat;
  background-position: right 5% center;
  opacity: .55;
  pointer-events: none;
}
.page-hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0; z-index: 2;
}
.page-hero-content {
  position: relative;
  z-index: 3;
  padding: 36px 60px 60px;
}
.page-hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 2.8rem);
  font-weight: 900;
  letter-spacing: -.025em;
  color: var(--ink);
  margin-bottom: 8px;
}
.page-hero-content p {
  font-size: .95rem;
  color: var(--ink-3);
  line-height: 1.7;
  max-width: 480px;
}

/* ══════════════════════════════════════
   MAIN LAYOUT
══════════════════════════════════════ */
.support-layout {
  background: var(--off-white);
  padding: 48px 60px 80px;
}
.support-inner {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 380px;
  gap: 28px;
  align-items: start;
}

/* ══════════════════════════════════════
   CHAT PANEL
══════════════════════════════════════ */
.chat-panel {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow-md);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  height: 680px;
  position: sticky;
  top: calc(var(--nav-h) + 20px);
}

/* Chat header */
.chat-header {
  background: linear-gradient(135deg, var(--lav) 0%, var(--mint) 100%);
  padding: 18px 22px;
  display: flex;
  align-items: center;
  gap: 14px;
  flex-shrink: 0;
}
.chat-bot-avatar {
  width: 46px; height: 46px;
  border-radius: 50%;
  background: rgba(255,255,255,.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 1.5rem;
  flex-shrink: 0;
  border: 2px solid rgba(255,255,255,.5);
}
.chat-bot-info h3 { font-weight: 700; font-size: .95rem; color: var(--ink); }
.chat-bot-info p  { font-size: .75rem; color: var(--ink-3); display: flex; align-items: center; gap: 5px; }
.online-dot {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: #48BB78;
  display: inline-block;
  animation: onlinePulse 2s infinite;
}
@@keyframes onlinePulse {
  0%,100% { box-shadow: 0 0 0 0 rgba(72,187,120,.4); }
  50%      { box-shadow: 0 0 0 5px rgba(72,187,120,0); }
}
.chat-tts-btn {
  margin-left: auto;
  padding: 6px 12px;
  border-radius: var(--radius-pill);
  border: 1.5px solid rgba(255,255,255,.5);
  background: rgba(255,255,255,.25);
  font-size: .75rem;
  font-weight: 700;
  color: var(--ink);
  cursor: pointer;
  transition: all .2s;
  flex-shrink: 0;
}
.chat-tts-btn:hover, .chat-tts-btn.on {
  background: rgba(255,255,255,.5);
  border-color: rgba(255,255,255,.8);
}

/* Messages area */
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 20px;
  display: flex;
  flex-direction: column;
  gap: 14px;
  background: #fafafa;
  scroll-behavior: smooth;
}
.chat-messages::-webkit-scrollbar { width: 4px; }
.chat-messages::-webkit-scrollbar-thumb { background: var(--mint-d); border-radius: 2px; }

/* Message bubbles */
.msg { display: flex; gap: 9px; max-width: 85%; }
.msg.bot  { align-self: flex-start; }
.msg.user { align-self: flex-end; flex-direction: row-reverse; }
.msg-av {
  width: 30px; height: 30px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: .95rem;
  flex-shrink: 0;
  margin-top: 2px;
}
.msg.bot  .msg-av { background: var(--mint); }
.msg.user .msg-av { background: var(--lav);  }
.msg-bubble {
  padding: 11px 15px;
  border-radius: 18px;
  font-size: .875rem;
  line-height: 1.6;
  color: var(--ink);
}
.msg.bot  .msg-bubble {
  background: #fff;
  border: 1px solid #E2E8F0;
  border-bottom-left-radius: 4px;
}
.msg.user .msg-bubble {
  background: var(--lav);
  border-bottom-right-radius: 4px;
}
.msg-time {
  font-size: .65rem;
  color: var(--ink-5);
  margin-top: 4px;
  display: block;
  text-align: right;
}
.msg.bot .msg-time { text-align: left; }

/* Typing indicator */
.typing-indicator {
  display: none;
  align-self: flex-start;
  gap: 9px;
}
.typing-indicator.show { display: flex; }
.typing-dots {
  background: #fff;
  border: 1px solid #E2E8F0;
  border-radius: 18px;
  border-bottom-left-radius: 4px;
  padding: 12px 16px;
  display: flex;
  gap: 4px;
  align-items: center;
}
.typing-dots span {
  width: 7px; height: 7px;
  border-radius: 50%;
  background: var(--ink-5);
  animation: typingBounce 1.2s infinite ease-in-out;
}
.typing-dots span:nth-child(2) { animation-delay: .2s; }
.typing-dots span:nth-child(3) { animation-delay: .4s; }
@@keyframes typingBounce {
  0%,60%,100% { transform: translateY(0); }
  30%          { transform: translateY(-6px); }
}

/* Quick replies */
.quick-replies {
  display: flex;
  flex-wrap: wrap;
  gap: 7px;
  margin-top: 8px;
}
.qr-btn {
  padding: 6px 13px;
  border-radius: var(--radius-pill);
  border: 1.5px solid var(--mint-d);
  background: rgba(178,223,219,.15);
  font-size: .78rem;
  font-weight: 600;
  color: var(--mint-dd);
  cursor: pointer;
  transition: all .2s;
}
.qr-btn:hover { background: var(--mint); color: var(--ink); }

/* Input row */
.chat-input-row {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 14px 16px;
  border-top: 1px solid #f0f0f0;
  background: #fff;
  flex-shrink: 0;
}
.chat-input {
  flex: 1;
  padding: 11px 16px;
  border: 1.5px solid #E2E8F0;
  border-radius: var(--radius-pill);
  font-family: 'DM Sans', sans-serif;
  font-size: .875rem;
  color: var(--ink);
  outline: none;
  transition: all .2s;
  background: var(--off-white);
}
.chat-input:focus {
  border-color: var(--mint-d);
  box-shadow: 0 0 0 3px rgba(178,223,219,.3);
  background: #fff;
}
.chat-send {
  width: 42px; height: 42px;
  border-radius: 50%;
  border: none;
  background: var(--peach-d);
  color: #fff;
  font-size: 1.1rem;
  cursor: pointer;
  transition: all .2s;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 3px 10px rgba(255,138,101,.35);
}
.chat-send:hover {
  background: var(--peach-dd);
  transform: scale(1.08);
}
.chat-send:disabled {
  background: #E2E8F0;
  box-shadow: none;
  cursor: not-allowed;
  transform: none;
}

/* ══════════════════════════════════════
   RIGHT SIDEBAR
══════════════════════════════════════ */
.sidebar { display: flex; flex-direction: column; gap: 18px; }

/* Contact card */
.contact-card {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.contact-card-header {
  background: linear-gradient(135deg, var(--peach) 0%, var(--lav) 100%);
  padding: 18px 20px;
}
.contact-card-header h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.1rem;
  font-weight: 900;
  margin-bottom: 2px;
}
.contact-card-header p { font-size: .78rem; color: var(--ink-3); }
.contact-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 14px 20px;
  border-bottom: 1px solid rgba(0,0,0,.06);
  cursor: pointer;
  transition: background .2s;
}
.contact-item:last-child { border-bottom: none; }
.contact-item:hover { background: var(--sky); }
.contact-icon {
  width: 38px; height: 38px;
  border-radius: 12px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.2rem;
  flex-shrink: 0;
}
.contact-label { font-weight: 700; font-size: .85rem; color: var(--ink); }
.contact-value { font-size: .76rem; color: var(--ink-4); margin-top: 1px; }

/* FAQ card */
.faq-card {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.faq-card-header {
  padding: 18px 20px 14px;
  border-bottom: 1px solid rgba(0,0,0,.06);
}
.faq-card-header h3 {
  font-weight: 700;
  font-size: .97rem;
  color: var(--ink);
}
.faq-item {
  border-bottom: 1px solid rgba(0,0,0,.06);
  overflow: hidden;
}
.faq-item:last-child { border-bottom: none; }
.faq-question {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 14px 20px;
  cursor: pointer;
  font-size: .85rem;
  font-weight: 600;
  color: var(--ink);
  transition: background .2s;
  gap: 10px;
}
.faq-question:hover { background: var(--sky); }
.faq-arrow {
  font-size: .75rem;
  color: var(--ink-4);
  transition: transform .25s;
  flex-shrink: 0;
}
.faq-item.open .faq-arrow { transform: rotate(180deg); }
.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height .3s ease, padding .3s ease;
  font-size: .82rem;
  color: var(--ink-3);
  line-height: 1.65;
  padding: 0 20px;
}
.faq-item.open .faq-answer {
  max-height: 200px;
  padding: 0 20px 14px;
}

/* Quick links */
.quick-links-card {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 18px 20px;
}
.quick-links-card h3 {
  font-weight: 700;
  font-size: .9rem;
  color: var(--ink);
  margin-bottom: 12px;
}
.ql-btn {
  display: flex;
  align-items: center;
  gap: 10px;
  width: 100%;
  padding: 10px 14px;
  border-radius: 12px;
  border: 1.5px solid #E2E8F0;
  background: var(--off-white);
  font-family: 'DM Sans', sans-serif;
  font-size: .82rem;
  font-weight: 600;
  color: var(--ink-2);
  cursor: pointer;
  transition: all .2s;
  margin-bottom: 8px;
  text-align: left;
}
.ql-btn:last-child { margin-bottom: 0; }
.ql-btn:hover { border-color: var(--mint-d); background: var(--sky); }

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@@media (max-width: 1100px) {
  .support-inner { grid-template-columns: 1fr; }
  .chat-panel { position: static; height: 580px; }
  .sidebar { display: grid; grid-template-columns: 1fr 1fr; }
}
@@media (max-width: 900px) {
  .support-layout { padding: 36px 24px 60px; }
  .page-hero-content { padding: 32px 24px 56px; }
}
@@media (max-width: 600px) {
  .sidebar { grid-template-columns: 1fr; }
  .chat-panel { height: 500px; }
}
</style>
</head>
