        <button class="ql-btn" onclick="quickSend('How do I update my profile?')">👤 Account & profile</button>
      </div>

      <!-- Contact -->
      <div class="contact-card">
        <div class="contact-card-header">
          <h3>Contact Us 📞</h3>
          <p>Prefer to talk to a human? We've got you.</p>
        </div>
        <div class="contact-item" onclick="window.location.href='mailto:support@bridgeup.org'">
          <div class="contact-icon" style="background:var(--sky)">📧</div>
