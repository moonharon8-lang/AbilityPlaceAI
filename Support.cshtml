      <div class="chat-header">
        <div class="chat-bot-avatar">🤖</div>
        <div class="chat-bot-info">
          <h3>BridgeUp Assistant</h3>
          <p><span class="online-dot"></span> Online · Powered by Gemini</p>
        </div>
        <button class="chat-tts-btn" id="ttsBtnChat" onclick="toggleTTS()">🔊 TTS</button>
      </div>

      <div class="chat-messages" id="chatMessages"></div>

      <!-- Typing indicator -->
      <div class="typing-indicator" id="typingIndicator">
