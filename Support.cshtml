    <script>
        window.addEventListener('mouseover', initLandbot, { once: true });
        window.addEventListener('touchstart', initLandbot, { once: true });
        var myLandbot;
        function initLandbot() {
          if (!myLandbot) {
            var s = document.createElement('script');
            s.type = "module"
            s.async = true;
            s.addEventListener('load', function() {
              myLandbot = new Landbot.Popup({
                configUrl: 'https://storage.googleapis.com/landbot.online/v3/H-3412628-ZG834BK3N10PWEIA/index.json',
              });
            });
            s.src = 'https://cdn.landbot.io/landbot-3/landbot-3.0.0.mjs';
            var x = document.getElementsByTagName('script')[0];
            x.parentNode.insertBefore(s, x);
          }
        }
    </script>
<script>
// ══════════════════════════════════════
// GEMINI API KEY
// ══════════════════════════════════════
// TODO: replace with your real Gemini API key
// Get it from: https://aistudio.google.com/app/apikey
// IMPORTANT: In production, never expose API keys in frontend code.
// Route calls through a Supabase Edge Function or backend instead.
// Example Edge Function: supabase/functions/chat/index.ts
const GEMINI_API_KEY = 'YOUR_GEMINI_API_KEY_HERE'
const GEMINI_URL = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${GEMINI_API_KEY}`

// System prompt — tells Gemini who it is and how to behave
const SYSTEM_PROMPT = `You are the BridgeUp AI assistant — a warm, knowledgeable, and accessible support bot for an inclusive education platform in Egypt and the Arab world.

BridgeUp serves:
- People with disabilities (ADHD, Autism, Down Syndrome, Deaf, Mute, Blind/Low Vision)
- Parents and guardians of disabled individuals
- Special education teachers
- Coaches and therapists

BridgeUp offers:
- Self-paced accessible courses
- Live classes with certified instructors
- Therapy and coaching session bookings
- Egyptian, Arabic, and American Sign Language lessons
- A network of 85+ partner centers across Egypt
- Volunteering opportunities
- AI-powered support (that's you!)
- Text to speech and other accessibility features

Your personality:
- Warm, calm, and encouraging — never clinical or cold
- Simple, clear language (avoid jargon)
- Supportive and patient
- Brief answers unless more detail is needed
- Always offer to help further

If someone asks something you don't know, say so honestly and suggest they contact the team at support@bridgeup.org or call +20 100 000 0000.

Respond in the same language the user writes in (Arabic or English). Keep responses concise — 1-3 short paragraphs maximum unless the user asks for more detail.`

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
let conversationHistory = []   // { role: 'user'|'model', parts: [{text}] }
let ttsOn = false
let isLoading = false

// ══════════════════════════════════════
// NAV
// ══════════════════════════════════════
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10)
})
function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('open')
}
document.querySelectorAll('.mobile-menu-link').forEach(l => {
  l.addEventListener('click', () => document.getElementById('mobileMenu').classList.remove('open'))
})

// ══════════════════════════════════════
// CHAT INIT — welcome message
// ══════════════════════════════════════
function initChat() {
  const welcomeMsg = `Hello! 👋 I'm the BridgeUp assistant, powered by Gemini AI. I can help you with:\n\n• Finding the right course for your needs\n• Booking therapy or coaching sessions\n• Learning about sign language\n• Finding centers near you\n• Any other questions about BridgeUp\n\nHow can I help you today?`
  addMessage('bot', welcomeMsg)

  // Quick reply suggestions
  const qrDiv = document.createElement('div')
  qrDiv.className = 'quick-replies'
  qrDiv.innerHTML = [
    '📚 Browse courses', '📅 Book a session',
    '🤟 Sign language', '🏥 Find a center'
  ].map(label => `<button class="qr-btn" onclick="quickSend('${label}')">${label}</button>`).join('')

  document.getElementById('chatMessages').appendChild(qrDiv)
  scrollBottom()
}

// ══════════════════════════════════════
// SEND MESSAGE
// ══════════════════════════════════════
async function sendMessage() {
  const input = document.getElementById('chatInput')
  const text  = input.value.trim()
  if (!text || isLoading) return

  input.value = ''
  isLoading = true
  document.getElementById('sendBtn').disabled = true

  addMessage('user', text)
  showTyping(true)

  // Add to history
  conversationHistory.push({ role: 'user', parts: [{ text }] })

  try {
    const response = await callGemini(text)
    showTyping(false)
    addMessage('bot', response)
    conversationHistory.push({ role: 'model', parts: [{ text: response }] })
    if (ttsOn) speak(response)
  } catch (err) {
    showTyping(false)
    const errMsg = GEMINI_API_KEY === 'YOUR_GEMINI_API_KEY_HERE'
      ? '🔑 Gemini API key not set yet. Add your key to support.html to enable AI responses. In the meantime, contact us at support@bridgeup.org!'
      : '😕 Something went wrong. Please try again or contact our team at support@bridgeup.org.'
    addMessage('bot', errMsg)
  }

  isLoading = false
  document.getElementById('sendBtn').disabled = false
  document.getElementById('chatInput').focus()
}

// ══════════════════════════════════════
// GEMINI API CALL
// ══════════════════════════════════════
async function callGemini(userText) {
  const body = {
    system_instruction: {
      parts: [{ text: SYSTEM_PROMPT }]
    },
    contents: conversationHistory,
    generationConfig: {
      temperature: 0.7,
      maxOutputTokens: 400,
    }
  }

  const res = await fetch(GEMINI_URL, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(body),
  })

  if (!res.ok) throw new Error(`Gemini API error: ${res.status}`)
  const data = await res.json()
  return data.candidates?.[0]?.content?.parts?.[0]?.text || 'Sorry, I couldn\'t generate a response.'
}

// ══════════════════════════════════════
// QUICK SEND
// ══════════════════════════════════════
function quickSend(text) {
  document.getElementById('chatInput').value = text
  sendMessage()
}

// ══════════════════════════════════════
// ADD MESSAGE TO UI
// ══════════════════════════════════════
function addMessage(role, text) {
  const messages = document.getElementById('chatMessages')
  const div = document.createElement('div')
  div.className = `msg ${role}`

  const now = new Date().toLocaleTimeString('en-EG', { hour: '2-digit', minute: '2-digit' })

  // Convert newlines to <br> and URLs to links
  const formatted = text
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/\n/g, '<br>')
    .replace(/(https?:\/\/[^\s<]+)/g, '<a href="$1" target="_blank" style="color:var(--peach-d);font-weight:600">$1</a>')

  div.innerHTML = `
    <div class="msg-av">${role === 'bot' ? '🤖' : '😊'}</div>
    <div>
      <div class="msg-bubble">${formatted}</div>
      <span class="msg-time">${now}</span>
    </div>`

  messages.appendChild(div)
  scrollBottom()
}

function scrollBottom() {
  const msgs = document.getElementById('chatMessages')
  msgs.scrollTop = msgs.scrollHeight
}

function showTyping(show) {
  document.getElementById('typingIndicator').classList.toggle('show', show)
  if (show) scrollBottom()
}

// ══════════════════════════════════════
// TTS
// ══════════════════════════════════════
function toggleTTS() {
  ttsOn = !ttsOn
  document.getElementById('ttsBtnChat').classList.toggle('on', ttsOn)
  showToast(ttsOn ? '🔊 Text to Speech enabled' : '🔇 Text to Speech disabled')
}

function speak(text) {
  if (!window.speechSynthesis) return
  window.speechSynthesis.cancel()
  const u = new SpeechSynthesisUtterance(text.replace(/<[^>]*>/g, ''))
  u.lang = 'en-US'
  u.rate = 0.9
  window.speechSynthesis.speak(u)
}

// ══════════════════════════════════════
// FAQ ACCORDION
// ══════════════════════════════════════
function toggleFAQ(item) {
  const isOpen = item.classList.contains('open')
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'))
  if (!isOpen) item.classList.add('open')
}

// ══════════════════════════════════════
// TOAST
// ══════════════════════════════════════
function showToast(msg) {
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 2800)
}

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
initChat()
</script>
</body>
</html>
