<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ABILITY PLACE</title>
    <link rel="stylesheet" href="~/css/global.css" />
    <style>

        /* ══════════════════════════════════════n
           HERO
        ══════════════════════════════════════ */
        .hero {
          min-height: 100vh;
          padding-top: var(--nav-h);
          display: grid;
          grid-template-columns: 1fr 1fr;
          align-items: stretch;
          position: relative;
          overflow: hidden;
        }

        /* Left half — sky + birds */
        .hero-sky {
          background: var(--sky);
          position: relative;
          overflow: hidden;
          min-height: calc(100vh - var(--nav-h));
          display: flex;
          align-items: center;
          justify-content: center;
        }
        .hero-birds-img {
          position: absolute;
          inset: 0;
            background-image: url('/image/ability2.png');
          background-size: 90%;
          background-repeat: no-repeat;
          background-position: center 30%;
          opacity: .95;
        }
        .hero-sky-edge {
          position: absolute;
          top: 0; right: -2px;
          height: 100%; width: 80px;
          background: linear-gradient(to right, transparent, #fff);
          z-index: 2;
        }

        /* Floating card over the birds */
        .hero-float-card {
          position: absolute;
          bottom: 14%;
          left: 50%;
          transform: translateX(-50%);
          background: #fff;
          border-radius: 18px;
          padding: 16px 20px;
          box-shadow: var(--shadow-md);
          display: flex;
          align-items: center;
          gap: 12px;
          z-index: 4;
          white-space: nowrap;
          animation: floatY 4s ease-in-out infinite;
        }
        @@keyframes floatY {
          0%,100% { transform: translateX(-50%) translateY(0); }
          50%      { transform: translateX(-50%) translateY(-8px); }
        }
        .hfc-icon { font-size: 1.8rem; }
        .hfc-t { font-weight: 700; font-size: .88rem; color: var(--ink); }
        .hfc-s { font-size: .75rem; color: var(--ink-4); margin-top: 1px; }

        /* Right half — text content */
        .hero-content {
          background: #fff;
          display: flex;
          align-items: center;
          padding: 80px 60px 80px 52px;
        }
        .hero-content-inner { max-width: 520px; }

        .hero-eyebrow {
          display: inline-flex;
          align-items: center;
          gap: 8px;
          padding: 7px 16px 7px 10px;
          border-radius: var(--radius-pill);
          background: var(--sky);
          border: 1.5px solid var(--mint);
          font-size: .78rem;
          font-weight: 700;
          color: var(--mint-dd);
          margin-bottom: 22px;
          letter-spacing: .02em;
        }
        .hero-dot {
          width: 8px; height: 8px;
          border-radius: 50%;
          background: var(--mint-dd);
          animation: blink 2s ease-in-out infinite;
        }
        @@keyframes blink {
          0%,100% { opacity: 1; transform: scale(1); }
          50%      { opacity: .4; transform: scale(.75); }
        }

        .hero-content h1 {
          font-family: 'Playfair Display', serif;
          font-size: clamp(2.6rem, 4vw, 3.8rem);
          font-weight: 900;
          line-height: 1.1;
          letter-spacing: -.03em;
          color: var(--ink);
          margin-bottom: 20px;
        }
        .hero-content h1 em {
          font-style: italic;
          color: var(--peach-d);
        }

        .hero-content p {
          font-size: 1.05rem;
          color: var(--ink-3);
          line-height: 1.75;
          margin-bottom: 36px;
          max-width: 440px;
        }

        .hero-btns {
          display: flex;
          gap: 12px;
          flex-wrap: wrap;
          margin-bottom: 40px;
        }

        .social-proof { display: flex; align-items: center; gap: 14px; }
        .sp-avatars { display: flex; }
        .sp-avatars span {
          width: 34px; height: 34px;
          border-radius: 50%;
          border: 2.5px solid #fff;
          background: var(--sky);
          display: flex; align-items: center; justify-content: center;
          font-size: 1rem;
          margin-left: -9px;
          box-shadow: 0 2px 8px rgba(0,0,0,.1);
        }
        .sp-avatars span:first-child { margin-left: 0; }
        .sp-text { font-size: .84rem; color: var(--ink-3); }
        .sp-text strong { color: var(--ink); font-weight: 700; }

        /* ══════════════════════════════════════
           ACCESSIBILITY STRIP
        ══════════════════════════════════════ */
        .a11y-strip {
          background: var(--ink);
          padding: 28px 60px;
          display: flex;
          align-items: center;
          justify-content: space-between;
          gap: 16px;
          flex-wrap: wrap;
          position: relative;
          overflow: hidden;
        }
        .a11y-strip::after {
          content: '';
          position: absolute;
          right: -60px; top: -60px;
          width: 220px; height: 220px;
          border-radius: 50%;
          background: radial-gradient(circle, rgba(178,223,219,.1) 0%, transparent 65%);
          pointer-events: none;
        }
        .a11y-item { display: flex; align-items: center; gap: 12px; }
        .a11y-icon {
          width: 44px; height: 44px;
          border-radius: 12px;
          display: flex; align-items: center; justify-content: center;
          font-size: 1.3rem; flex-shrink: 0;
        }
        .a11y-t { font-weight: 700; font-size: .88rem; color: #fff; display: block; }
        .a11y-s { font-size: .74rem; color: rgba(255,255,255,.45); display: block; margin-top: 1px; }

        /* ══════════════════════════════════════
           STATS
        ══════════════════════════════════════ */
        .stats-row {
          background: var(--sky);
          display: grid;
          grid-template-columns: repeat(5, 1fr);
          gap: 2px;
        }
        .stat-box {
          background: #fff;
          padding: 36px 20px;
          text-align: center;
          transition: background .2s;
          cursor: default;
        }
        .stat-box:hover { background: var(--sky); }
        .stat-n {
          font-family: 'Playfair Display', serif;
          font-size: 2.4rem;
          font-weight: 900;
          color: var(--peach-d);
          display: block;
          line-height: 1;
        }
        .stat-l { font-size: .8rem; color: var(--ink-4); margin-top: 8px; font-weight: 500; }

        /* ══════════════════════════════════════
           FEATURES
        ══════════════════════════════════════ */
        .features-section { padding: 100px 60px; background: #fff; }
        .features-grid {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 16px;
          margin-top: 52px;
        }
        .feat-card {
          padding: 28px 22px;
          border-radius: var(--radius);
          border: 1.5px solid rgba(0,0,0,.07);
          background: #fff;
          cursor: pointer;
          transition: all .25s;
          position: relative;
          overflow: hidden;
        }
        .feat-card::after {
          content: '';
          position: absolute;
          bottom: 0; left: 0; right: 0;
          height: 3px;
          background: var(--peach-d);
          transform: scaleX(0);
          transform-origin: left;
          transition: transform .3s;
        }
        .feat-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); border-color: transparent; }
        .feat-card:hover::after { transform: scaleX(1); }
        .feat-icon {
          width: 50px; height: 50px;
          border-radius: 14px;
          display: flex; align-items: center; justify-content: center;
          font-size: 1.5rem;
          margin-bottom: 16px;
        }
        .feat-card h3 { font-weight: 700; font-size: .97rem; margin-bottom: 8px; }
        .feat-card p  { font-size: .82rem; color: var(--ink-4); line-height: 1.65; }
        .feat-arrow {
          display: inline-flex;
          align-items: center;
          gap: 4px;
          margin-top: 14px;
          font-size: .8rem;
          font-weight: 700;
          color: var(--peach-d);
          transition: gap .2s;
        }
        .feat-card:hover .feat-arrow { gap: 8px; }

        /* ══════════════════════════════════════
           WHO WE SERVE
        ══════════════════════════════════════ */
        .serve-section { padding: 100px 60px; background: var(--sky); }
        .serve-grid {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 16px;
          margin-top: 52px;
        }
        .serve-card {
          background: #fff;
          border-radius: var(--radius);
          padding: 32px 24px;
          box-shadow: var(--shadow);
          transition: transform .25s;
        }
        .serve-card:hover { transform: translateY(-4px); }
        .sc-icon { font-size: 2.6rem; margin-bottom: 14px; display: block; }
        .serve-card h3 {
          font-family: 'Playfair Display', serif;
          font-size: 1.05rem;
          font-weight: 700;
          margin-bottom: 10px;
        }
        .serve-card p { font-size: .83rem; color: var(--ink-3); line-height: 1.65; }
        .serve-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 14px; }
        .serve-tag {
          padding: 3px 10px;
          border-radius: var(--radius-pill);
          font-size: .7rem;
          font-weight: 700;
          background: var(--sky);
          color: var(--mint-dd);
        }

        .disabilities-row { margin-top: 60px; text-align: center; }
        .disabilities-row h3 {
          font-family: 'Playfair Display', serif;
          font-size: 1.4rem;
          font-weight: 700;
          margin-bottom: 20px;
        }
        .disability-chips { display: flex; flex-wrap: wrap; gap: 12px; justify-content: center; }
        .d-chip {
          padding: 10px 22px;
          border-radius: var(--radius-pill);
          background: #fff;
          border: 1.5px solid rgba(0,0,0,.07);
          font-size: .88rem;
          font-weight: 600;
          color: var(--ink-2);
          box-shadow: var(--shadow);
          transition: all .2s;
          cursor: default;
        }
        .d-chip:hover { border-color: var(--peach-d); transform: translateY(-2px); }

        /* ══════════════════════════════════════
           COURSES PREVIEW
        ══════════════════════════════════════ */
        .courses-section { padding: 100px 60px; background: #fff; }
        .courses-header {
          display: flex;
          align-items: flex-end;
          justify-content: space-between;
          flex-wrap: wrap;
          gap: 20px;
          margin-bottom: 40px;
        }
        .courses-grid {
          display: grid;
          grid-template-columns: repeat(4, 1fr);
          gap: 16px;
        }
        .course-card {
          border-radius: var(--radius);
          border: 1.5px solid rgba(0,0,0,.07);
          overflow: hidden;
          background: #fff;
          cursor: pointer;
          transition: all .25s;
        }
        .course-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); border-color: transparent; }
        .cc-thumb {
          height: 130px;
          display: flex; align-items: center; justify-content: center;
          font-size: 3.2rem;
          position: relative;
        }
        .cc-free {
          position: absolute;
          top: 10px; right: 10px;
          padding: 3px 10px;
          border-radius: var(--radius-pill);
          background: rgba(255,255,255,.88);
          font-size: .7rem;
          font-weight: 700;
          color: #276749;
          backdrop-filter: blur(4px);
        }
        .cc-body { padding: 18px; }
        .cc-cat {
          font-size: .7rem;
          font-weight: 700;
          text-transform: uppercase;
          letter-spacing: .06em;
          color: var(--lav-d);
          margin-bottom: 6px;
        }
        .cc-body h3 { font-weight: 700; font-size: .92rem; line-height: 1.4; margin-bottom: 10px; }
        .cc-meta { display: flex; gap: 10px; font-size: .74rem; color: var(--ink-4); margin-bottom: 14px; }
        .cc-btn {
          width: 100%;
          padding: 10px;
          border-radius: var(--radius-pill);
          border: none;
          background: var(--peach);
          color: var(--ink);
          font-weight: 700;
          font-size: .84rem;
          transition: all .2s;
        }
        .cc-btn:hover { background: var(--peach-d); color: #fff; }

        /* ══════════════════════════════════════
           TESTIMONIALS
        ══════════════════════════════════════ */
        .testi-section {
          padding: 100px 60px;
          background: var(--ink);
          position: relative;
          overflow: hidden;
        }
        .testi-section::before {
          content: '';
          position: absolute;
          top: -80px; left: -80px;
          width: 340px; height: 340px;
          border-radius: 50%;
          background: radial-gradient(circle, rgba(178,223,219,.07) 0%, transparent 65%);
          pointer-events: none;
        }
        .testi-section .eyebrow { background: rgba(255,255,255,.1); color: rgba(255,255,255,.65); }
        .testi-section .section-title { color: #fff; }
        .testi-section .section-sub   { color: rgba(255,255,255,.45); }
        .testi-grid {
          display: grid;
          grid-template-columns: repeat(3, 1fr);
          gap: 18px;
          margin-top: 52px;
          position: relative; z-index: 1;
        }
        .testi-card {
          background: rgba(255,255,255,.06);
          border: 1px solid rgba(255,255,255,.1);
          border-radius: var(--radius);
          padding: 28px;
          transition: all .25s;
        }
        .testi-card:hover { background: rgba(255,255,255,.09); transform: translateY(-4px); }
        .testi-stars { color: var(--peach); font-size: .85rem; margin-bottom: 14px; }
        .testi-quote-mark {
          font-family: 'Playfair Display', serif;
          font-size: 3rem;
          color: var(--peach);
          line-height: .8;
          margin-bottom: 10px;
          display: block;
        }
        .testi-text { font-size: .88rem; color: rgba(255,255,255,.72); line-height: 1.75; margin-bottom: 22px; }
        .testi-author { display: flex; align-items: center; gap: 12px; }
        .testi-avatar {
          width: 42px; height: 42px;
          border-radius: 50%;
          display: flex; align-items: center; justify-content: center;
          font-size: 1.2rem; flex-shrink: 0;
        }
        .testi-name { font-weight: 700; font-size: .88rem; color: #fff; }
        .testi-role { font-size: .74rem; color: rgba(255,255,255,.4); margin-top: 2px; }

        /* ══════════════════════════════════════
           CTA
        ══════════════════════════════════════ */
        .cta-section {
          padding: 100px 60px;
          background: linear-gradient(135deg, var(--sky) 0%, var(--lav) 50%, var(--peach) 100%);
          text-align: center;
          position: relative;
          overflow: hidden;
        }
        .cta-section::before {
          content: '';
          position: absolute;
          top: 50%; left: 50%;
          transform: translate(-50%, -50%);
          width: 500px; height: 500px;
          border-radius: 50%;
          background: radial-gradient(circle, rgba(255,255,255,.3) 0%, transparent 65%);
          pointer-events: none;
        }
        .cta-section h2 {
          font-family: 'Playfair Display', serif;
          font-size: clamp(2rem, 3.5vw, 3rem);
          font-weight: 900;
          letter-spacing: -.025em;
          margin-bottom: 16px;
          position: relative; z-index: 1;
        }
        .cta-section p {
          font-size: 1rem;
          color: var(--ink-3);
          max-width: 440px;
          margin: 0 auto 36px;
          line-height: 1.75;
          position: relative; z-index: 1;
        }
        .cta-btns {
          display: flex;
          gap: 14px;
          justify-content: center;
          flex-wrap: wrap;
          position: relative; z-index: 1;
        }

        /* ══════════════════════════════════════
           RESPONSIVE
        ══════════════════════════════════════ */
        @@media (max-width: 1100px) {
          .features-grid { grid-template-columns: repeat(2, 1fr); }
          .courses-grid  { grid-template-columns: repeat(2, 1fr); }
          .testi-grid    { grid-template-columns: repeat(2, 1fr); }
          .serve-grid    { grid-template-columns: repeat(2, 1fr); }
        }
        @@media (max-width: 900px) {
          .hero { grid-template-columns: 1fr; }
          .hero-sky { min-height: 45vh; }
          .hero-content { padding: 48px 32px; }
          .hero-float-card { bottom: 6%; }
          .a11y-strip { padding: 28px 32px; }
          .stats-row { grid-template-columns: repeat(3, 1fr); }
          .features-section,
          .serve-section,
          .courses-section,
          .testi-section,
          .cta-section { padding: 72px 32px; }
        }
        @@media (max-width: 600px) {
          .stats-row     { grid-template-columns: repeat(2, 1fr); }
          .testi-grid    { grid-template-columns: 1fr; }
          .serve-grid    { grid-template-columns: 1fr; }
          .features-grid { grid-template-columns: 1fr; }
          .courses-grid  { grid-template-columns: 1fr; }
          .hero-content h1 { font-size: 2.4rem; }
          .hero-float-card { display: none; }
        }
    </style>
</head>
