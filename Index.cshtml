                        <span>😊</span><span>🧑‍🦽</span><span>👩‍🏫</span><span>👨‍👩‍👧</span>
                    </div>
                    <div class="sp-text">Trusted by <strong>4,200+</strong> learners across the Arab world</div>
                </div>
            </div>
        </div>
    </section>

    <!-- ══════ A11Y STRIP ══════ -->
    <div class="a11y-strip">
        <div class="a11y-item">
            <div class="a11y-icon" style="background:rgba(178,223,219,.12)">🧠</div>
            <div><span class="a11y-t">ADHD-Friendly</span><span class="a11y-s">Structured, distraction-free</span></div>
        </div>
        <div class="a11y-item">
            <div class="a11y-icon" style="background:rgba(209,196,233,.12)">🧩</div>
            <div><span class="a11y-t">Autism Support</span><span class="a11y-s">Predictable, sensory-safe design</span></div>
        </div>
        <div class="a11y-item">
            <div class="a11y-icon" style="background:rgba(255,204,188,.12)">🤟</div>
            <div><span class="a11y-t">Sign Language</span><span class="a11y-s">ESL, ASL & Arabic SL built-in</span></div>
        </div>
        <div class="a11y-item">
            <div class="a11y-icon" style="background:rgba(178,223,219,.12)">🔊</div>
            <div><span class="a11y-t">Text to Speech</span><span class="a11y-s">Every page reads aloud</span></div>
        </div>
        <div class="a11y-item">
            <div class="a11y-icon" style="background:rgba(255,204,188,.12)">👁️</div>
            <div><span class="a11y-t">Screen Reader</span><span class="a11y-s">Full ARIA support</span></div>
        </div>
    </div>

    <!-- ══════ STATS ══════ -->
    <div class="stats-row" id="statsRow">
        <div class="stat-box reveal"><span class="stat-n" id="s1">0</span><div class="stat-l">Active Learners</div></div>
        <div class="stat-box reveal"><span class="stat-n" id="s2">0</span><div class="stat-l">Courses Available</div></div>
        <div class="stat-box reveal"><span class="stat-n" id="s3">0</span><div class="stat-l">Partner Centers</div></div>
        <div class="stat-box reveal"><span class="stat-n" id="s4">0</span><div class="stat-l">Disabilities Served</div></div>
        <div class="stat-box reveal"><span class="stat-n" id="s5">0</span><div class="stat-l">Satisfaction Rate</div></div>
    </div>

