<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — Sign In</title>
<link rel="stylesheet" href="~/css/global.css"/>
<style>
/* ── AUTH LAYOUT ── */
body { background: var(--sky); }

.auth-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* Sky with real birds */
.auth-sky {
  width: 100%;
  height: 52vh;
  background: var(--sky);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}

.auth-sky-birds {
  position: absolute;
  inset: 0;
            background-image: url('/image/ability3.png');
  background-size: 80%;
  background-repeat: no-repeat;
  background-position: center 20%;
}

/* Wave SVG */
.auth-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0;
}

/* White content area */
.auth-body {
  background: #fff;
  flex: 1;
  position: relative;
  z-index: 1;
}

/* Two column layout */
.auth-cols {
  max-width: 820px;
  margin: 0 auto;
  padding: 48px 40px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

/* LEFT — form */
.auth-form-col h1 {
  font-family: 'Playfair Display', serif;
  font-size: 2.4rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 28px;
  letter-spacing: -.02em;
}

.auth-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 22px 0;
  color: var(--ink-5);
  font-size: .8rem;
}
.auth-divider::before,
.auth-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: #E2E8F0;
}

.forgot-link {
  text-align: center;
  margin-top: 12px;
}
.forgot-link a {
  font-size: .82rem;
  color: var(--ink-4);
  font-style: italic;
  text-decoration: none;
  transition: color .2s;
}
.forgot-link a:hover { color: var(--peach-d); }

/* RIGHT — welcome panel */
.auth-welcome-col {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding-top: 8px;
}

.auth-welcome-col h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2.8rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 22px;
  letter-spacing: -.02em;
}

.auth-welcome-btns {
  display: flex;
  flex-direction: column;
  gap: 12px;
  width: 100%;
  max-width: 200px;
  margin-bottom: 28px;
}

.social-label {
  font-size: .78rem;
  color: var(--ink-4);
  margin-bottom: 12px;
  font-weight: 500;
}

.social-row {
  display: flex;
  gap: 12px;
}

.social-btn {
  width: 48px; height: 48px;
  border-radius: 50%;
  border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 2px 10px rgba(0,0,0,.12);
}
.social-btn:hover { transform: scale(1.1); box-shadow: 0 4px 16px rgba(0,0,0,.18); }
.social-btn.google   { background: #fff; border: 1.5px solid #E2E8F0; }
.social-btn.facebook { background: #1877F2; }
.social-btn.linkedin { background: #0A66C2; }

/* Error state */
.input-error { border-bottom-color: #FC8181 !important; }
.error-msg {
  font-size: .78rem;
  color: #E53E3E;
  margin-top: 5px;
  display: none;
}
.error-msg.show { display: block; }

/* Responsive */
@@media (max-width: 640px) {
  .auth-cols {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 36px 24px 48px;
  }
  .auth-welcome-col { align-items: center; text-align: center; }
  .auth-welcome-btns { max-width: 100%; }
  .social-row { justify-content: center; }
  .auth-sky { height: 42vh; }
}
</style>
</head>
<body>

<div class="auth-page">

  <!-- SKY + BIRDS -->
  <div class="auth-sky">
    <div class="auth-sky-birds"></div>
    <!-- Wave transition -->
    <div class="auth-wave">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%;display:block">
        <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1380,20 1440,40 L1440,80 L0,80 Z" fill="rgba(255,255,255,.6)"/>
        <path d="M0,55 C200,20 400,75 600,50 C800,25 1000,70 1200,45 C1320,30 1400,60 1440,55 L1440,80 L0,80 Z" fill="#fff"/>
      </svg>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="auth-body">
    <div class="auth-cols">

      <!-- LEFT: FORM -->
      <div class="auth-form-col">
        <h1>Sign in</h1>

        <div class="form-group">
          <input
            class="form-input-line"
            type="email"
            id="email"
            placeholder="Email"
            autocomplete="email"
          />
          <div class="error-msg" id="email-err">Please enter a valid email.</div>
        </div>

        <div class="form-group">
          <input
            class="form-input-line"
            type="password"
            id="password"
            placeholder="Password"
            autocomplete="current-password"
          />
          <div class="error-msg" id="pw-err">Please enter your password.</div>
        </div>

        <div style="margin-top: 28px;">
          <button class="btn-soft btn-block" id="signinBtn" onclick="handleSignIn()">
            Sign in
          </button>
        </div>

        <div class="forgot-link">
          <a href="#">Forgot your password?</a>
        </div>
      </div>

      <!-- RIGHT: WELCOME -->
      <div class="auth-welcome-col">
        <h2>Welcome</h2>

        <div class="auth-welcome-btns">
                        <button class="btn-soft" onclick="window.location='/Home/Signin'" style="width:100%">Sign in</button>
          <button class="btn-soft" onclick="window.location='/Home/Signup'" style="width:100%">Sign up</button>
        </div>

        <div class="social-label">Or continue with</div>
        <div class="social-row">
          <!-- Google -->
          <button class="social-btn google" title="Sign in with Google" onclick="handleGoogle()">
            <svg width="20" height="20" viewBox="0 0 48 48">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
          </button>
          <!-- Facebook -->
          <button class="social-btn facebook" title="Sign in with Facebook" onclick="handleFacebook()">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.93-1.956 1.886v2.288h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </button>
          <!-- LinkedIn -->
          <button class="social-btn linkedin" title="Sign in with LinkedIn" onclick="handleLinkedin()">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </button>
        </div>

        <div style="margin-top: 24px; font-size: .84rem; color: var(--ink-4);">
          New here?
                        <a href="/Home/Signup" style="color: var(--peach-d); font-weight: 700;">Create an account →</a>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
// ── SIGN IN (placeholder — wire to Supabase later) ──
async function handleSignIn() {
  const email    = document.getElementById('email').value.trim()
  const password = document.getElementById('password').value
  let valid = true

  // Clear errors
  document.getElementById('email-err').classList.remove('show')
  document.getElementById('pw-err').classList.remove('show')
  document.getElementById('email').classList.remove('input-error')
  document.getElementById('password').classList.remove('input-error')

  if (!email || !email.includes('@@')) {
    document.getElementById('email-err').classList.add('show')
    document.getElementById('email').classList.add('input-error')
    valid = false
  }
  if (!password) {
    document.getElementById('pw-err').classList.add('show')
    document.getElementById('password').classList.add('input-error')
    valid = false
  }
  if (!valid) return

  // ── TODO: replace with real Supabase auth ──
  // const { data, error } = await signIn(email, password)
  // if (error) { showToast('❌ ' + error.message); return }

  // Placeholder success
  showToast('✅ Signed in! Redirecting…')
          setTimeout(() => window.location.href = '/Home/Index', 1200)
}

function handleGoogle()   { showToast('Google sign-in coming soon!') }
function handleFacebook() { showToast('Facebook sign-in coming soon!') }
function handleLinkedin() { showToast('LinkedIn sign-in coming soon!') }

// Enter key
document.addEventListener('keydown', e => {
  if (e.key === 'Enter') handleSignIn()
})

// Toast
function showToast(msg) {
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 2800)
}
</script>
</body>
</html>