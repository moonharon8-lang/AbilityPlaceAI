            <a class="nav-link" href="/Home/Courses">Courses</a>
            <a class="nav-link" href="/Home/Classes">Classes</a>
            <a class="nav-link" href="/Home/Bookings">Bookings</a>
            <a class="nav-link" href="/Home/Sign Language">Sign Language</a>
            <a class="nav-link" href="/Home/Centers">Centers</a>
            <a class="nav-link" href="/Home/About">About Us</a>
            <a class="nav-link" href="/Home/Support">Support</a>
            <a class="nav-link" href="/Home/Volunteering">Volunteering</a>
  </div>
  <div class="nav-actions">
            <button class="btn-nav-ghost" onclick="window.location='/Home/Signin'">Sign in</button>
    <button class="btn-nav-fill"  onclick="window.location='/Home/Signin'">Get started</button>
  </div>
  <button class="nav-hamburger" id="hamBtn" onclick="toggleMenu()">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
        <a class="mobile-menu-link" href="/Home/Home">🏠 Home</a>
        <a class="mobile-menu-link" href="/Home/Courses">📚 Courses</a>
        <a class="mobile-menu-link" href="/Home/Classes">🎓 Classes</a>
        <a class="mobile-menu-link" href="/Home/Bookings">📅 Bookings</a>
        <a class="mobile-menu-link" href="/Home/ SignLanguage">🤟 Sign Language</a>
        <a class="mobile-menu-link" href="/Home/Centers">🏥 Centers</a>
        <a class="mobile-menu-link" href="/Home/Volunteering">🤝 Volunteer</a>
        <a class="mobile-menu-link" href="/Home/About">ℹ️ About Us</a>
        <a class="mobile-menu-link active" href="/Home/News">📰 News</a>
        <a class="mobile-menu-link" href="/Home/Support">💬 Support</a>
        <div class="mobile-menu-divider"></div>
        <a class="mobile-menu-link" href="/Home/Signin" style="color:var(--peach-d);font-weight:600">Sign in</a>
        <a class="mobile-menu-link" href="/Home/Signup" style="background:var(--peach);border-radius:14px;font-weight:700;text-align:center">Get started →</a>
</div>

<!-- ══════ PAGE HERO ══════ -->
<div class="page-hero">
  <div class="page-hero-birds"></div>
  <div class="page-hero-content">
    <div class="eyebrow">📅 Your sessions, your way</div>
    <h1>Book a Session</h1>
    <p>Choose a service, pick your provider, and book a time that works for you — therapy, coaching, and center appointments all in one place.</p>
  </div>
  <div class="page-hero-wave">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%;display:block">
      <path d="M0,30 C240,60 480,0 720,30 C960,60 1200,0 1440,30 L1440,60 L0,60 Z" fill="rgba(255,255,255,.6)"/>
      <path d="M0,45 C360,15 720,60 1080,35 C1260,22 1380,50 1440,45 L1440,60 L0,60 Z" fill="var(--off-white)"/>
    </svg>
  </div>
</div>

<!-- ══════ BOOKING FLOW ══════ -->
<div class="booking-wrapper">
  <div class="booking-inner">

    <!-- Stepper -->
    <div class="stepper" id="stepper">
      <div class="stepper-item active" id="st-1">
        <div class="stepper-circle">1</div>
        <div class="stepper-label">Service</div>
      </div>
      <div class="stepper-item" id="st-2">
        <div class="stepper-circle">2</div>
        <div class="stepper-label">Provider</div>
      </div>
      <div class="stepper-item" id="st-3">
        <div class="stepper-circle">3</div>
        <div class="stepper-label">Date & Time</div>
      </div>
      <div class="stepper-item" id="st-4">
        <div class="stepper-circle">4</div>
        <div class="stepper-label">Confirm</div>
      </div>
    </div>

    <!-- ══ STEP 1: SERVICE ══ -->
    <div class="step-panel active" id="panel-1">
      <div class="panel-title">What kind of session?</div>
      <div class="panel-sub">Pick the type of service you'd like to book.</div>

      <div class="service-grid" id="serviceGrid">
        <div class="service-card" onclick="selectService(this, 'therapy_1on1')" data-service="therapy_1on1">
          <div class="service-icon" style="background:var(--lav)">🧠</div>
          <div class="service-info">
            <h3>1-on-1 Therapy Session</h3>
            <p>Private session with a certified therapist — speech, sensory, behavioral, or psychological.</p>
            <span class="service-badge">Private · 50 min</span>
          </div>
        </div>
        <div class="service-card" onclick="selectService(this, 'group')" data-service="group">
          <div class="service-icon" style="background:var(--mint)">👥</div>
          <div class="service-info">
            <h3>Group Session</h3>
            <p>Join a small group session for shared learning, social skills practice, or peer support.</p>
            <span class="service-badge">Group · 60–90 min</span>
          </div>
        </div>
        <div class="service-card" onclick="selectService(this, 'center')" data-service="center">
          <div class="service-icon" style="background:var(--peach)">🏥</div>
          <div class="service-info">
            <h3>Center Appointment</h3>
            <p>In-person appointment at a partner center for diagnosis, assessment, or specialized therapy.</p>
            <span class="service-badge">In-person · varies</span>
          </div>
        </div>
        <div class="service-card" onclick="selectService(this, 'coach')" data-service="coach">
          <div class="service-icon" style="background:#DCEDC8">🏃</div>
          <div class="service-info">
            <h3>Coach / Trainer Session</h3>
            <p>Work with a certified coach on life skills, independence training, or behavioral development.</p>
            <span class="service-badge">Private · 45 min</span>
          </div>
        </div>
      </div>

      <div class="step-error" id="err-1">Please select a session type to continue.</div>

      <div class="step-nav">
        <span class="step-hint">Step 1 of 4</span>
        <button class="btn-primary" onclick="goStep(2)">Next: Choose Provider →</button>
      </div>
    </div>

    <!-- ══ STEP 2: PROVIDER ══ -->
    <div class="step-panel" id="panel-2">
      <div class="panel-title">Choose your provider</div>
      <div class="panel-sub" id="providerSub">Select who you'd like to book with.</div>

      <!--
        TODO: fetch providers from Supabase based on selected service type.
        Table: providers (id, name, specialty, rating, rate, avatar_emoji,
                          avatar_bg, tags[], service_types[], available)
        Query: supabase.from('providers')
                 .select('*')
                 .contains('service_types', [selectedService])
                 .eq('available', true)
      -->
      <div class="provider-list" id="providerList">
        <!-- Populated by renderProviders() based on selected service -->
      </div>

      <div class="step-error" id="err-2">Please select a provider to continue.</div>

      <div class="step-nav">
        <button class="btn-back" onclick="goStep(1)">← Back</button>
        <button class="btn-primary" onclick="goStep(3)">Next: Pick Date & Time →</button>
      </div>
    </div>

    <!-- ══ STEP 3: DATE & TIME ══ -->
    <div class="step-panel" id="panel-3">
      <div class="panel-title">Pick a date & time</div>
      <div class="panel-sub">All times shown in Cairo time (EET, UTC+2).</div>

      <div class="datetime-grid">
        <!-- Calendar -->
        <div class="dt-panel">
          <h3>📅 Select a date</h3>
          <div class="mini-cal">
            <div class="cal-header">
              <button class="cal-nav" onclick="prevMonth()">‹</button>
              <span id="calMonthLabel"></span>
              <button class="cal-nav" onclick="nextMonth()">›</button>
            </div>
            <div class="cal-grid" id="calGrid"></div>
          </div>
        </div>

        <!-- Time slots -->
        <div class="dt-panel">
          <h3>⏰ Select a time</h3>
          <div id="timeSlotWrap">
