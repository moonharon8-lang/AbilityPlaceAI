<script>

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
let currentStep     = 1
let selectedService  = null
let selectedProvider = null
let selectedDate     = null   // Date object
let selectedTime     = null   // string "HH:MM AM/PM"
let calYear, calMonth         // currently displayed calendar month

// ══════════════════════════════════════
// NAV
// ══════════════════════════════════════
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10)
})
function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('open')
}
document.querySelectorAll('.mobile-menu-link').forEach(l => {
  l.addEventListener('click', () => document.getElementById('mobileMenu').classList.remove('open'))
})

// ══════════════════════════════════════
// STEP NAVIGATION
// ══════════════════════════════════════
function goStep(n) {
  if (n > currentStep && !validateStep(currentStep)) return

  // Update stepper UI
  for (let i = 1; i <= 4; i++) {
    const st = document.getElementById('st-' + i)
    st.classList.remove('active', 'done')
    if (i < n) st.classList.add('done')
    if (i === n) st.classList.add('active')
  }

  document.getElementById('panel-' + currentStep).classList.remove('active')
  document.getElementById('panel-' + n).classList.add('active')
  currentStep = n

  if (n === 2) renderProviders()
  if (n === 4) populateSummary()

  window.scrollTo({ top: 0, behavior: 'smooth' })
}

// ══════════════════════════════════════
// VALIDATION
// ══════════════════════════════════════
function validateStep(step) {
  hideAllErrors()
  if (step === 1 && !selectedService) {
    showError('err-1'); return false
  }
  if (step === 2 && !selectedProvider) {
    showError('err-2'); return false
  }
  if (step === 3 && (!selectedDate || !selectedTime)) {
    showError('err-3'); return false
  }
  return true
}
function showError(id)  { document.getElementById(id).classList.add('show') }
function hideAllErrors(){ document.querySelectorAll('.step-error').forEach(e => e.classList.remove('show')) }

// ══════════════════════════════════════
// STEP 1 — SERVICE SELECTION
// ══════════════════════════════════════
function selectService(el, service) {
  document.querySelectorAll('.service-card').forEach(c => c.classList.remove('selected'))
  el.classList.add('selected')
  selectedService  = service
  selectedProvider = null   // reset downstream
  selectedDate     = null
  selectedTime     = null
}

const SERVICE_LABELS = {
  therapy_1on1: '1-on-1 Therapy Session',
  group:        'Group Session',
  center:       'Center Appointment',
  coach:        'Coach / Trainer Session',
}

// ══════════════════════════════════════
// STEP 2 — PROVIDERS
// Placeholder data — replace with Supabase query in TODO below
// ══════════════════════════════════════

// TODO: fetch from Supabase
// const { data: providers } = await supabase
//   .from('providers')
//   .select('*')
//   .contains('service_types', [selectedService])
//   .eq('available', true)
const PROVIDERS_DATA = [
  {
    id: 'p1', name: 'Dr. Sara Khalil',
    specialty: 'Speech & Language Therapist',
    rating: '4.9 ★', rate: '200 EGP / session',
    avatar: '👩‍⚕️', bg: 'var(--mint)',
    tags: ['Speech Therapy', 'Autism', 'ADHD'],
    service_types: ['therapy_1on1', 'group'],
  },
  {
    id: 'p2', name: 'Coach Ahmed Nasser',
    specialty: 'Behavioral Coach · ADHD & Autism',
    rating: '4.8 ★', rate: '180 EGP / session',
    avatar: '🧑‍🏫', bg: 'var(--lav)',
    tags: ['ADHD', 'Autism', 'Life Skills'],
    service_types: ['coach', 'therapy_1on1'],
  },
  {
    id: 'p3', name: 'Dr. Mona Ibrahim',
    specialty: 'Sensory Integration Therapist',
    rating: '5.0 ★', rate: '250 EGP / session',
    avatar: '👩‍🔬', bg: 'var(--peach)',
    tags: ['Sensory', 'Down Syndrome', 'Autism'],
    service_types: ['therapy_1on1', 'center'],
  },
  {
    id: 'p4', name: 'Hope Rehab Center',
    specialty: 'Diagnosis & Multidisciplinary Therapy',
    rating: '4.7 ★', rate: 'From 300 EGP',
    avatar: '🏥', bg: '#FFF9C4',
    tags: ['Diagnosis', 'Speech', 'Behavioral'],
    service_types: ['center', 'group'],
  },
  {
    id: 'p5', name: 'Ms. Layla Mostafa',
    specialty: 'Sign Language Instructor & Coach',
    rating: '4.9 ★', rate: '150 EGP / session',
    avatar: '🤟', bg: 'var(--sky)',
    tags: ['Sign Language', 'Deaf', 'Mute'],
    service_types: ['coach', 'group'],
  },
]

function renderProviders() {
  const list = document.getElementById('providerList')
  const sub  = document.getElementById('providerSub')

  const filtered = PROVIDERS_DATA.filter(p =>
    p.service_types.includes(selectedService)
  )

  sub.textContent = `${filtered.length} provider${filtered.length !== 1 ? 's' : ''} available for ${SERVICE_LABELS[selectedService]}`

  if (filtered.length === 0) {
    list.innerHTML = `<div style="text-align:center;padding:40px;color:var(--ink-4)">No providers available for this service type right now.</div>`
    return
  }

  list.innerHTML = filtered.map(p => `
    <div class="provider-card" id="pcard-${p.id}" onclick="selectProvider('${p.id}')">
      <div class="provider-avatar" style="background:${p.bg}">${p.avatar}</div>
      <div class="provider-info">
        <h3>${p.name}</h3>
        <p>${p.specialty}</p>
        <div class="provider-tags">
          ${p.tags.map(t => `<span class="provider-tag">${t}</span>`).join('')}
        </div>
      </div>
      <div class="provider-meta">
        <span class="provider-rating">${p.rating}</span>
        <span class="provider-rate">${p.rate}</span>
        <span class="provider-avail">Available</span>
      </div>
    </div>
  `).join('')
}

function selectProvider(id) {
  document.querySelectorAll('.provider-card').forEach(c => c.classList.remove('selected'))
  document.getElementById('pcard-' + id).classList.add('selected')
  selectedProvider = PROVIDERS_DATA.find(p => p.id === id)
}

// ══════════════════════════════════════
// STEP 3 — CALENDAR
// ══════════════════════════════════════
const MONTH_NAMES = ['January','February','March','April','May','June',
                     'July','August','September','October','November','December']
const DAY_LABELS  = ['Su','Mo','Tu','We','Th','Fr','Sa']

// Simulated fully-booked time slots per date string "YYYY-MM-DD"
// TODO: fetch from Supabase bookings table to get real availability
const FULL_SLOTS = {
  // example: '2025-04-15': ['9:00 AM', '10:00 AM']
}

function initCalendar() {
  const now = new Date()
  calYear  = now.getFullYear()
  calMonth = now.getMonth()
  renderCalendar()
}

function renderCalendar() {
  document.getElementById('calMonthLabel').textContent = `${MONTH_NAMES[calMonth]} ${calYear}`
  const grid = document.getElementById('calGrid')
  const today = new Date()
  today.setHours(0,0,0,0)

  const firstDay = new Date(calYear, calMonth, 1).getDay()
  const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate()

  let html = DAY_LABELS.map(d => `<div class="cal-day-label">${d}</div>`).join('')

  // Empty cells before first day
  for (let i = 0; i < firstDay; i++) {
    html += `<div class="cal-day empty"></div>`
  }

  for (let d = 1; d <= daysInMonth; d++) {
    const date = new Date(calYear, calMonth, d)
    date.setHours(0,0,0,0)
    const isPast = date < today
    const isToday = date.getTime() === today.getTime()
    const dateStr = formatDate(date)
    const isSelected = selectedDate && formatDate(selectedDate) === dateStr

    let cls = 'cal-day'
    if (isPast)    cls += ' past'
    if (isToday)   cls += ' today'
    if (isSelected) cls += ' selected'

    const clickHandler = isPast ? '' : `onclick="pickDate(${calYear}, ${calMonth}, ${d})"`
    html += `<div class="${cls}" ${clickHandler}>${d}</div>`
  }

  grid.innerHTML = html
}

function prevMonth() {
  calMonth--
  if (calMonth < 0) { calMonth = 11; calYear-- }
  renderCalendar()
}
function nextMonth() {
  calMonth++
  if (calMonth > 11) { calMonth = 0; calYear++ }
  renderCalendar()
}

function pickDate(y, m, d) {
  selectedDate = new Date(y, m, d)
  selectedTime = null
  renderCalendar()
  renderTimeSlots()
}

function renderTimeSlots() {
  const wrap   = document.getElementById('timeSlots')
  const prompt = document.getElementById('timePrompt')
  const legend = document.getElementById('slotLegend')
  const dateStr = formatDate(selectedDate)
  const fullSlots = FULL_SLOTS[dateStr] || []

  const ALL_SLOTS = [
    '9:00 AM','10:00 AM','11:00 AM','12:00 PM',
    '1:00 PM','2:00 PM','3:00 PM','4:00 PM','5:00 PM',
  ]

  prompt.style.display = 'none'
  wrap.style.display   = 'grid'
  legend.style.display = 'flex'

  wrap.innerHTML = ALL_SLOTS.map(slot => {
    const isFull     = fullSlots.includes(slot)
    const isSelected = selectedTime === slot
    let cls = 'time-slot'
    if (isFull)     cls += ' full'
    if (isSelected) cls += ' selected'
    const click = isFull ? '' : `onclick="pickTime('${slot}')"`
    return `<div class="${cls}" ${click}>${slot}${isFull ? '<br><span style="font-size:.65rem">Full</span>' : ''}</div>`
  }).join('')
}

function pickTime(time) {
  selectedTime = time
  renderTimeSlots()
}

// ══════════════════════════════════════
// STEP 4 — SUMMARY
// ══════════════════════════════════════
function populateSummary() {
  document.getElementById('sum-service').textContent  = SERVICE_LABELS[selectedService]  || '—'
  document.getElementById('sum-provider').textContent = selectedProvider ? selectedProvider.name : '—'
  document.getElementById('sum-date').textContent     = selectedDate
    ? selectedDate.toLocaleDateString('en-EG', { weekday:'long', year:'numeric', month:'long', day:'numeric' })
    : '—'
  document.getElementById('sum-time').textContent  = selectedTime || '—'
  const notes = document.getElementById('bookingNotes').value.trim()
  document.getElementById('sum-notes').textContent = notes || 'None'
  document.getElementById('sum-notes').style.fontStyle = notes ? 'normal' : 'italic'
}

// ══════════════════════════════════════
// CONFIRM BOOKING
// ══════════════════════════════════════
async function confirmBooking() {

  // ── TODO: insert into Supabase ──────────────────────────
  // const user = await getUser()
  // if (!user) { window.location = 'signin.html'; return }
  //
  // const { error } = await supabase.from('bookings').insert({
  //   user_id:     user.id,
  //   provider_id: selectedProvider.id,
  //   service:     selectedService,
  //   date:        selectedDate.toISOString().split('T')[0],
  //   time:        selectedTime,
  //   notes:       document.getElementById('bookingNotes').value.trim(),
  //   status:      'confirmed',
  // })
  // if (error) { showToast('❌ ' + error.message); return }
  // ── END TODO ─────────────────────────────────────────────

  // Show success state
  document.getElementById('stepper').style.display   = 'none'
  document.getElementById('panel-4').classList.remove('active')
  const success = document.getElementById('successState')
  success.classList.add('show')
  document.getElementById('successMsg').textContent =
    `Your ${SERVICE_LABELS[selectedService]} with ${selectedProvider.name} on ${
      selectedDate.toLocaleDateString('en-EG', { weekday:'long', month:'long', day:'numeric' })
    } at ${selectedTime} is confirmed. We'll send a reminder 24 hours before.`

  window.scrollTo({ top: 0, behavior: 'smooth' })
}

// ══════════════════════════════════════
// RESET
// ══════════════════════════════════════
function resetBooking() {
  selectedService  = null
  selectedProvider = null
  selectedDate     = null
  selectedTime     = null
  currentStep      = 1

  document.getElementById('successState').classList.remove('show')
  document.getElementById('stepper').style.display = 'flex'
  document.querySelectorAll('.service-card').forEach(c => c.classList.remove('selected'))

  for (let i = 1; i <= 4; i++) {
    const st = document.getElementById('st-' + i)
    st.classList.remove('active', 'done')
    document.getElementById('panel-' + i).classList.remove('active')
  }
  document.getElementById('st-1').classList.add('active')
  document.getElementById('panel-1').classList.add('active')
  window.scrollTo({ top: 0, behavior: 'smooth' })
}

// ══════════════════════════════════════
// HELPERS
// ══════════════════════════════════════
function formatDate(d) {
  return `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}-${String(d.getDate()).padStart(2,'0')}`
}

function showToast(msg) {
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 2800)
}

// ── INIT ──
initCalendar()
</script>
