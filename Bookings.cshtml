<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace— Bookings</title>
<link rel="stylesheet" href="~/css/global.css"/>
<style>

/* ══════════════════════════════════════
   PAGE HERO
══════════════════════════════════════ */
.page-hero {
  padding-top: var(--nav-h);
  background: var(--sky);
  position: relative;
  overflow: hidden;
  min-height: 240px;
  display: flex;
  align-items: flex-end;
}
.page-hero-birds {
  position: absolute;
  inset: 0;
  background-image: url('/image/ability4.png');
  background-size: 50%;
  background-repeat: no-repeat;
  background-position: right 5% center;
  opacity: .65;
  pointer-events: none;
}
.page-hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0; z-index: 2;
}
.page-hero-content {
  position: relative;
  z-index: 3;
  padding: 40px 60px 64px;
}
.page-hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  letter-spacing: -.025em;
  color: var(--ink);
  margin-bottom: 8px;
}
.page-hero-content p {
  font-size: 1rem;
  color: var(--ink-3);
  line-height: 1.7;
  max-width: 500px;
}

/* ══════════════════════════════════════
   BOOKING WRAPPER
══════════════════════════════════════ */
.booking-wrapper {
  padding: 52px 60px 80px;
  background: var(--off-white);
  min-height: 70vh;
}
.booking-inner {
  max-width: 1000px;
  margin: 0 auto;
}

/* ══════════════════════════════════════
   PROGRESS STEPPER
══════════════════════════════════════ */
.stepper {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 48px;
  gap: 0;
}
.stepper-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  flex: 1;
  max-width: 160px;
  position: relative;
}
.stepper-item:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 18px;
  left: 55%;
  width: 90%;
  height: 2px;
  background: #E2E8F0;
  transition: background .4s;
  z-index: 0;
}
.stepper-item.done:not(:last-child)::after { background: var(--mint-dd); }

.stepper-circle {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 2px solid #E2E8F0;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: .85rem;
  font-weight: 700;
  color: var(--ink-4);
  position: relative; z-index: 1;
  transition: all .3s;
}
.stepper-item.active .stepper-circle {
  background: var(--peach-d);
  border-color: var(--peach-d);
  color: #fff;
  box-shadow: 0 4px 14px rgba(255,138,101,.4);
}
.stepper-item.done .stepper-circle {
  background: var(--mint-dd);
  border-color: var(--mint-dd);
  color: #fff;
}
.stepper-label {
  font-size: .72rem;
  font-weight: 600;
  color: var(--ink-5);
  text-align: center;
  white-space: nowrap;
}
.stepper-item.active .stepper-label { color: var(--peach-d); }
.stepper-item.done   .stepper-label { color: var(--mint-dd); }

/* ══════════════════════════════════════
   STEP PANELS
══════════════════════════════════════ */
.step-panel { display: none; }
.step-panel.active { display: block; animation: fadeSlide .3s ease; }
@@keyframes fadeSlide {
  from { opacity: 0; transform: translateY(12px); }
  to   { opacity: 1; transform: translateY(0); }
}

.panel-title {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 6px;
}
.panel-sub {
  font-size: .88rem;
  color: var(--ink-4);
  margin-bottom: 28px;
}

/* ══════════════════════════════════════
   STEP 1 — SERVICE TYPE
══════════════════════════════════════ */
.service-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14px;
}
.service-card {
  background: #fff;
  border-radius: var(--radius);
  border: 2px solid #E2E8F0;
  padding: 28px 24px;
  cursor: pointer;
  transition: all .2s;
  display: flex;
  align-items: flex-start;
  gap: 16px;
}
.service-card:hover { border-color: var(--mint-d); transform: translateY(-2px); }
.service-card.selected {
  border-color: var(--peach-d);
  background: #fff8f6;
  box-shadow: 0 0 0 4px rgba(255,138,101,.12);
}
.service-icon {
  width: 52px; height: 52px;
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem;
  flex-shrink: 0;
}
.service-info h3 { font-weight: 700; font-size: 1rem; margin-bottom: 5px; }
.service-info p  { font-size: .82rem; color: var(--ink-4); line-height: 1.55; }
.service-badge {
  display: inline-block;
  margin-top: 10px;
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  font-size: .7rem;
  font-weight: 700;
  background: var(--sky);
  color: var(--mint-dd);
}

/* ══════════════════════════════════════
   STEP 2 — PROVIDER
══════════════════════════════════════ */
.provider-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.provider-card {
  background: #fff;
  border-radius: var(--radius);
  border: 2px solid #E2E8F0;
  padding: 20px 22px;
  cursor: pointer;
  transition: all .2s;
  display: flex;
  align-items: center;
  gap: 16px;
}
.provider-card:hover { border-color: var(--mint-d); }
.provider-card.selected {
  border-color: var(--peach-d);
  background: #fff8f6;
  box-shadow: 0 0 0 4px rgba(255,138,101,.1);
}
.provider-avatar {
  width: 54px; height: 54px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.7rem;
  flex-shrink: 0;
}
.provider-info { flex: 1; }
.provider-info h3 { font-weight: 700; font-size: .97rem; margin-bottom: 3px; }
.provider-info p  { font-size: .8rem; color: var(--ink-4); margin-bottom: 6px; }
.provider-tags { display: flex; flex-wrap: wrap; gap: 6px; }
.provider-tag {
  padding: 2px 9px;
  border-radius: var(--radius-pill);
  background: var(--sky);
  font-size: .7rem;
  font-weight: 700;
  color: var(--mint-dd);
}
.provider-meta {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4px;
  flex-shrink: 0;
}
.provider-rating { font-size: .85rem; font-weight: 700; color: var(--ink); }
.provider-rate   { font-size: .78rem; color: var(--ink-4); }
.provider-avail  {
  font-size: .72rem;
  font-weight: 700;
  color: #276749;
  background: #C8E6C9;
  padding: 2px 9px;
  border-radius: var(--radius-pill);
}

/* ══════════════════════════════════════
   STEP 3 — DATE & TIME
══════════════════════════════════════ */
.datetime-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}
.dt-panel {
  background: #fff;
  border-radius: var(--radius);
  padding: 24px;
  box-shadow: var(--shadow);
}
.dt-panel h3 {
  font-weight: 700;
  font-size: .95rem;
  margin-bottom: 16px;
  color: var(--ink);
}

/* Mini calendar */
.mini-cal { width: 100%; }
.cal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14px;
}
.cal-header span {
  font-weight: 700;
  font-size: .9rem;
}
.cal-nav {
  background: none;
  border: none;
  font-size: 1.1rem;
  cursor: pointer;
  color: var(--ink-3);
  padding: 4px 8px;
  border-radius: 8px;
  transition: background .2s;
}
.cal-nav:hover { background: var(--sky); }
.cal-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 3px;
}
.cal-day-label {
  text-align: center;
  font-size: .68rem;
  font-weight: 700;
  color: var(--ink-4);
  padding-bottom: 6px;
}
.cal-day {
  aspect-ratio: 1;
  display: flex; align-items: center; justify-content: center;
  border-radius: 10px;
  font-size: .8rem;
  font-weight: 500;
  cursor: pointer;
  transition: all .15s;
  color: var(--ink);
}
.cal-day:hover:not(.empty):not(.past) { background: var(--peach); }
.cal-day.past   { color: var(--ink-5); cursor: default; }
.cal-day.empty  { cursor: default; }
.cal-day.today  { font-weight: 800; color: var(--peach-d); }
.cal-day.selected {
  background: var(--peach-d);
  color: #fff;
  font-weight: 700;
  box-shadow: 0 3px 10px rgba(255,138,101,.35);
}

/* Time slots */
.time-slots {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}
.time-slot {
  padding: 10px 6px;
  border-radius: 12px;
  border: 1.5px solid #E2E8F0;
  background: var(--off-white);
  font-size: .8rem;
  font-weight: 600;
  text-align: center;
  cursor: pointer;
  transition: all .2s;
  color: var(--ink-3);
}
.time-slot:hover:not(.full) { border-color: var(--mint-d); color: var(--ink); }
.time-slot.selected {
  background: var(--mint);
  border-color: var(--mint-dd);
  color: #00695C;
  font-weight: 700;
}
.time-slot.full {
  opacity: .4;
  cursor: not-allowed;
  text-decoration: line-through;
}
.slot-legend {
  display: flex;
  gap: 14px;
  margin-top: 14px;
  font-size: .72rem;
  color: var(--ink-4);
}
.legend-dot {
  width: 10px; height: 10px;
  border-radius: 3px;
  display: inline-block;
  margin-right: 4px;
}

/* ══════════════════════════════════════
   STEP 4 — CONFIRM
══════════════════════════════════════ */
.confirm-card {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
  max-width: 560px;
  margin: 0 auto;
}
.confirm-header {
  background: linear-gradient(135deg, var(--lav), var(--peach));
  padding: 28px 28px 24px;
}
.confirm-header h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.4rem;
  font-weight: 900;
  margin-bottom: 4px;
}
.confirm-header p { font-size: .85rem; color: var(--ink-3); }
.confirm-body { padding: 24px 28px; }
.confirm-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12px 0;
  border-bottom: 1px solid rgba(0,0,0,.06);
  font-size: .88rem;
}
.confirm-row:last-child { border-bottom: none; }
.confirm-row .cr-label { color: var(--ink-4); font-weight: 500; }
.confirm-row .cr-value { font-weight: 700; color: var(--ink); text-align: right; max-width: 60%; }
.confirm-footer { padding: 0 28px 28px; }
.confirm-note {
  background: var(--sky);
  border-radius: 14px;
  padding: 14px 16px;
  font-size: .82rem;
  color: var(--ink-3);
  margin-bottom: 20px;
  line-height: 1.6;
}

/* ══════════════════════════════════════
   SUCCESS STATE
══════════════════════════════════════ */
.success-state {
  display: none;
  text-align: center;
  padding: 60px 24px;
  animation: fadeSlide .4s ease;
}
.success-state.show { display: block; }
.success-icon {
  font-size: 4rem;
  margin-bottom: 20px;
  animation: popIn .4s cubic-bezier(.175,.885,.32,1.275);
}
@@keyframes popIn {
  from { transform: scale(0); opacity: 0; }
  to   { transform: scale(1); opacity: 1; }
}
.success-state h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 900;
  margin-bottom: 10px;
}
.success-state p { color: var(--ink-3); font-size: .95rem; margin-bottom: 32px; max-width: 400px; margin-left: auto; margin-right: auto; }

/* ══════════════════════════════════════
   NAVIGATION BUTTONS
══════════════════════════════════════ */
.step-nav {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 32px;
  gap: 12px;
}
.btn-back {
  padding: 13px 26px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: transparent;
  font-size: .9rem;
  font-weight: 600;
  color: var(--ink-3);
  transition: all .2s;
}
.btn-back:hover { border-color: var(--ink-3); color: var(--ink); }
.step-hint {
  font-size: .8rem;
  color: var(--ink-5);
}

/* ══════════════════════════════════════
   ERROR MESSAGE
══════════════════════════════════════ */
.step-error {
  display: none;
  background: #FFF5F5;
  border: 1.5px solid #FED7D7;
  border-radius: 12px;
  padding: 12px 16px;
  font-size: .84rem;
  color: #C53030;
  margin-top: 14px;
  font-weight: 500;
}
.step-error.show { display: block; }

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@@media (max-width: 900px) {
  .booking-wrapper  { padding: 36px 24px 60px; }
  .page-hero-content{ padding: 36px 24px 56px; }
  .service-grid     { grid-template-columns: 1fr; }
  .datetime-grid    { grid-template-columns: 1fr; }
  .stepper          { gap: 0; }
  .stepper-label    { display: none; }
}
@@media (max-width: 560px) {
  .time-slots { grid-template-columns: repeat(2, 1fr); }
  .step-nav   { flex-direction: column-reverse; }
  .btn-back, .btn-primary { width: 100%; justify-content: center; }
}
</style>
</head>
<body>

<!-- ══════ NAV ══════ -->
<nav class="nav" id="navbar">
  <a class="nav-logo" href="home.html">Ability<span>Place</span></a>
  <div class="nav-links">
