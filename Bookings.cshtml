        <div class="confirm-footer">
          <div class="confirm-note">
            📧 A confirmation will be sent to your email. You can manage or cancel your booking from your <a href="profile.html" style="color:var(--peach-d);font-weight:700">Profile</a> up to 24 hours before the session.
          </div>
          <!--
            TODO: wire to Supabase on confirm.
            Insert into bookings table:
            supabase.from('bookings').insert({
              user_id:     currentUser.id,
              provider_id: selectedProvider.id,
              service:     selectedService,
