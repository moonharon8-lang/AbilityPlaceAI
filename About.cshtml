<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — Who Are We</title>
<link rel="stylesheet" href="/css/global.css"/>
<style>

/* ══════════════════════════════════════
   HERO — full sky with birds
══════════════════════════════════════ */
.about-hero {
  padding-top: var(--nav-h);
  min-height: 70vh;
  background: var(--sky);
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
}
.hero-birds-bg {
  position: absolute;
  inset: 0;
            background-image: url('/image/ability.png');
            background-size: 75%;
  background-repeat: no-repeat;
  background-position: center 35%;
  opacity: .55;
  pointer-events: none;
}
.hero-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0; z-index: 2;
}
.about-hero-content {
  position: relative;
  z-index: 3;
  max-width: 1100px;
  margin: 0 auto;
  padding: 60px 60px 100px;
  text-align: center;
  width: 100%;
}
.about-hero-content .eyebrow { margin-bottom: 18px; }
.about-hero-content h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2.8rem, 6vw, 4.5rem);
  font-weight: 900;
  letter-spacing: -.035em;
  line-height: 1.1;
  color: var(--ink);
  margin-bottom: 22px;
}
.about-hero-content h1 em {
  font-style: italic;
  color: var(--peach-d);
}
.about-hero-content p {
  font-size: 1.1rem;
  color: var(--ink-3);
  line-height: 1.8;
  max-width: 620px;
  margin: 0 auto 36px;
}
.hero-stat-row {
  display: flex;
  gap: 40px;
  justify-content: center;
  flex-wrap: wrap;
}
.hero-stat {
  text-align: center;
  background: rgba(255,255,255,.75);
  backdrop-filter: blur(10px);
  padding: 18px 28px;
  border-radius: var(--radius);
  border: 1.5px solid rgba(255,255,255,.9);
  box-shadow: var(--shadow);
}
.hero-stat-n {
  font-family: 'Playfair Display', serif;
  font-size: 2rem;
  font-weight: 900;
  color: var(--peach-d);
  display: block;
  line-height: 1;
}
.hero-stat-l {
  font-size: .78rem;
  color: var(--ink-4);
  margin-top: 5px;
  font-weight: 500;
}

/* ══════════════════════════════════════
   STORY SECTION
══════════════════════════════════════ */
.story-section {
  padding: 100px 60px;
  background: #fff;
}
.story-grid {
  max-width: 1100px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.story-visual {
  position: relative;
}
.story-card-main {
  background: linear-gradient(135deg, var(--lav) 0%, var(--peach) 100%);
  border-radius: var(--radius);
  padding: 40px;
  box-shadow: var(--shadow-lg);
}
.story-card-main h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 900;
  margin-bottom: 14px;
}
.story-card-main p {
  font-size: .9rem;
  color: var(--ink-3);
  line-height: 1.75;
}
.story-float {
  position: absolute;
  background: #fff;
  border-radius: 16px;
  padding: 14px 18px;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  gap: 10px;
  animation: floatY 5s ease-in-out infinite;
}
.story-float:nth-child(2) { bottom: -20px; left: -20px; animation-delay: -2s; }
.story-float:nth-child(3) { top: -16px; right: -16px; animation-delay: -3.5s; }
@@keyframes floatY {
  0%,100% { transform: translateY(0); }
  50%      { transform: translateY(-8px); }
}
.sf-icon { font-size: 1.5rem; }
.sf-t  { font-weight: 700; font-size: .85rem; color: var(--ink); }
.sf-s  { font-size: .72rem; color: var(--ink-4); }

.story-text .section-title { margin-bottom: 16px; }
.story-text p {
  font-size: .95rem;
  color: var(--ink-3);
  line-height: 1.8;
  margin-bottom: 18px;
}
.story-text p:last-child { margin-bottom: 0; }

/* ══════════════════════════════════════
   MISSION & VISION
══════════════════════════════════════ */
.mv-section {
  padding: 100px 60px;
  background: var(--sky);
}
.mv-inner { max-width: 1100px; margin: 0 auto; }
.mv-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin-top: 52px;
}
.mv-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 40px;
  box-shadow: var(--shadow);
  position: relative;
  overflow: hidden;
}
.mv-card::before {
  content: '';
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 5px;
}
.mv-card.mission::before { background: var(--peach-d); }
.mv-card.vision::before  { background: var(--lav-d); }
.mv-card-icon {
  font-size: 2.8rem;
  margin-bottom: 18px;
  display: block;
}
.mv-card h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.5rem;
  font-weight: 900;
  margin-bottom: 14px;
}
.mv-card p {
  font-size: .95rem;
  color: var(--ink-3);
  line-height: 1.8;
}

/* ══════════════════════════════════════
   VALUES
══════════════════════════════════════ */
.values-section {
  padding: 100px 60px;
  background: #fff;
}
.values-inner { max-width: 1100px; margin: 0 auto; }
.values-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
  margin-top: 52px;
}
.value-card {
  padding: 32px 28px;
  border-radius: var(--radius);
  background: #fff;
  border: 1.5px solid rgba(0,0,0,.07);
  transition: all .25s;
  position: relative;
  overflow: hidden;
}
.value-card::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 4px;
  transform: scaleX(0);
  transform-origin: left;
  transition: transform .3s;
}
.value-card:hover { transform: translateY(-5px); box-shadow: var(--shadow-lg); border-color: transparent; }
.value-card:hover::after { transform: scaleX(1); }
.value-card:nth-child(1)::after { background: var(--peach-d); }
.value-card:nth-child(2)::after { background: var(--lav-d); }
.value-card:nth-child(3)::after { background: var(--mint-dd); }
.value-card:nth-child(4)::after { background: #66BB6A; }
.value-card:nth-child(5)::after { background: var(--peach-d); }
.value-card:nth-child(6)::after { background: var(--lav-d); }
.value-icon {
  width: 52px; height: 52px;
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem;
  margin-bottom: 18px;
}
.value-card h3 { font-weight: 700; font-size: 1rem; margin-bottom: 8px; }
.value-card p  { font-size: .84rem; color: var(--ink-4); line-height: 1.7; }

/* ══════════════════════════════════════
   TEAM
══════════════════════════════════════ */
.team-section {
  padding: 100px 60px;
  background: var(--sky);
}
.team-inner { max-width: 1100px; margin: 0 auto; }
.team-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 18px;
  margin-top: 52px;
}
.team-card {
  background: #fff;
  border-radius: var(--radius);
  padding: 28px 20px;
  text-align: center;
  box-shadow: var(--shadow);
  transition: transform .25s;
}
.team-card:hover { transform: translateY(-5px); }
.team-avatar {
  width: 76px; height: 76px;
  border-radius: 50%;
  margin: 0 auto 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 2.2rem;
  border: 3px solid #fff;
  box-shadow: var(--shadow);
}
.team-card h3 { font-weight: 700; font-size: .97rem; margin-bottom: 4px; }
.team-card .team-role { font-size: .8rem; color: var(--ink-4); margin-bottom: 10px; }
.team-card .team-bio  { font-size: .78rem; color: var(--ink-3); line-height: 1.6; }
.team-social { display: flex; gap: 8px; justify-content: center; margin-top: 12px; }
.team-soc {
  width: 30px; height: 30px;
  border-radius: 8px;
  background: var(--sky);
  display: flex; align-items: center; justify-content: center;
  font-size: .7rem;
  font-weight: 700;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
  text-decoration: none;
}
.team-soc:hover { background: var(--mint); color: var(--ink); }

/* ══════════════════════════════════════
   PARTNERS
══════════════════════════════════════ */
.partners-section {
  padding: 80px 60px;
  background: #fff;
}
.partners-inner { max-width: 1100px; margin: 0 auto; text-align: center; }
.partners-row {
  display: flex;
  gap: 16px;
  justify-content: center;
  flex-wrap: wrap;
  margin-top: 40px;
}
.partner-chip {
  padding: 14px 24px;
  border-radius: var(--radius);
  background: var(--off-white);
  border: 1.5px solid rgba(0,0,0,.07);
  font-size: .88rem;
  font-weight: 600;
  color: var(--ink-2);
  display: flex;
  align-items: center;
  gap: 8px;
  transition: all .2s;
  cursor: default;
}
.partner-chip:hover { border-color: var(--mint-d); transform: translateY(-2px); }

/* ══════════════════════════════════════
   CTA
══════════════════════════════════════ */
.cta-section {
  padding: 100px 60px;
  background: var(--ink);
  text-align: center;
  position: relative;
  overflow: hidden;
}
.cta-section::before {
  content: '';
  position: absolute;
  top: -100px; left: -100px;
  width: 400px; height: 400px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(178,223,219,.08) 0%, transparent 65%);
  pointer-events: none;
}
.cta-section::after {
  content: '';
  position: absolute;
  bottom: -80px; right: -80px;
  width: 320px; height: 320px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(209,196,233,.08) 0%, transparent 65%);
  pointer-events: none;
}
.cta-section h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 900;
  color: #fff;
  letter-spacing: -.025em;
  margin-bottom: 16px;
  position: relative; z-index: 1;
}
.cta-section p {
  font-size: 1rem;
  color: rgba(255,255,255,.55);
  max-width: 480px;
  margin: 0 auto 36px;
  line-height: 1.75;
  position: relative; z-index: 1;
}
.cta-btns {
  display: flex;
  gap: 14px;
  justify-content: center;
  flex-wrap: wrap;
  position: relative; z-index: 1;
}
.btn-cta-white {
  padding: 14px 32px;
  border-radius: var(--radius-pill);
  border: 2px solid rgba(255,255,255,.3);
  background: transparent;
  color: #fff;
  font-family: 'DM Sans', sans-serif;
  font-size: .95rem;
  font-weight: 700;
  cursor: pointer;
  transition: all .25s;
}
.btn-cta-white:hover {
  background: rgba(255,255,255,.1);
  border-color: rgba(255,255,255,.6);
}

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@@media (max-width: 1100px) {
  .team-grid   { grid-template-columns: repeat(2, 1fr); }
  .values-grid { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 900px) {
  .about-hero-content { padding: 48px 24px 80px; }
  .story-section,
  .mv-section,
  .values-section,
  .team-section,
  .partners-section,
  .cta-section { padding: 72px 24px; }
  .story-grid  { grid-template-columns: 1fr; gap: 48px; }
  .mv-grid     { grid-template-columns: 1fr; }
  .story-visual { display: none; }
}
@@media (max-width: 600px) {
  .values-grid { grid-template-columns: 1fr; }
  .team-grid   { grid-template-columns: 1fr 1fr; }
  .hero-stat-row { gap: 12px; }
  .hero-stat   { padding: 14px 18px; }
}
</style>
</head>
<body>

