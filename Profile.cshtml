      </div>
      <span class="booking-status" style="background:${b.statusBg};color:${b.statusColor}">${b.status.charAt(0).toUpperCase() + b.status.slice(1)}</span>
      <div class="booking-actions">
        ${b.status !== 'completed' ? `<button class="bk-btn" onclick="showToast('Opening booking details…')">Details</button>` : ''}
        ${b.status !== 'completed' ? `<button class="bk-btn danger" onclick="cancelBooking('${b.id}')">Cancel</button>` : `<button class="bk-btn" onclick="showToast('Booking archived.')">Archive</button>`}
      </div>
    </div>`).join('')

  list.querySelectorAll('.reveal').forEach((el, i) => {
    el.style.transitionDelay = (i * 60) + 'ms'
    revealObserver.observe(el)
  })
}

