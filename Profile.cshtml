</div>

<!-- ══════ PROFILE HEADER ══════ -->
<div class="profile-header">
  <div class="profile-header-inner">
    <div class="avatar-wrap">
      <div class="avatar-circle" id="avatarCircle">😊</div>
      <div class="avatar-edit" onclick="switchTab('settings')" title="Edit profile">✏️</div>
    </div>

    <div class="profile-info">
      <!--
        TODO: fetch user from Supabase on page load
        const user = await getUser()
        const { data: profile } = await supabase
          .from('profiles').select('*').eq('id', user.id).single()
        Then populate: name, email, role, disabilities
      -->
      <div class="profile-name" id="profileName">Mars</div>
      <div class="profile-email" id="profileEmail">mars@bridgeup.org</div>
      <div class="profile-badges">
        <span class="p-badge" style="background:var(--lav);color:#4527A0" id="roleBadge">🧑‍🦽 Person with Disability</span>
        <span class="p-badge" style="background:var(--sky);color:var(--mint-dd)">📍 Egypt</span>
        <span class="p-badge" style="background:#C8E6C9;color:#1B5E20">✓ Verified</span>
      </div>
    </div>

    <div class="profile-header-actions">
      <button class="btn-secondary" onclick="switchTab('settings')">✏️ Edit Profile</button>
      <button class="btn-primary" onclick="window.location='bookings.html'">📅 Book Session</button>
    </div>
  </div>

  <!-- Wavy bottom -->
  <div style="line-height:0;margin-top:32px">
    <svg viewBox="0 0 1440 40" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%;display:block">
      <path d="M0,20 C360,40 720,0 1080,20 C1260,30 1380,10 1440,20 L1440,40 L0,40 Z" fill="var(--off-white)"/>
    </svg>
  </div>
</div>

<!-- ══════ TAB BAR ══════ -->
<div class="tab-bar">
  <div class="tab-bar-inner">
    <button class="tab-btn active" id="tab-overview"  onclick="switchTab('overview')">📊 Overview</button>
    <button class="tab-btn"        id="tab-courses"   onclick="switchTab('courses')">📚 My Courses <span class="tab-count" id="courseCount">3</span></button>
    <button class="tab-btn"        id="tab-bookings"  onclick="switchTab('bookings')">📅 My Bookings <span class="tab-count" id="bookingCount">2</span></button>
    <button class="tab-btn"        id="tab-settings"  onclick="switchTab('settings')">⚙️ Settings</button>
  </div>
</div>

<!-- ══════ PROFILE BODY ══════ -->
<div class="profile-body">
  <div class="profile-body-inner">

    <!-- ══ OVERVIEW TAB ══ -->
    <div class="tab-panel active" id="panel-overview">

      <!-- Mini stats -->
      <div class="stats-mini reveal">
        <div class="stat-mini"><span class="stat-mini-n">3</span><div class="stat-mini-l">Courses enrolled</div></div>
        <div class="stat-mini"><span class="stat-mini-n">2</span><div class="stat-mini-l">Upcoming sessions</div></div>
        <div class="stat-mini"><span class="stat-mini-n">75%</span><div class="stat-mini-l">Avg. progress</div></div>
        <div class="stat-mini"><span class="stat-mini-n">7🔥</span><div class="stat-mini-l">Day streak</div></div>
      </div>

      <div class="overview-grid">

        <!-- Course progress -->
        <div class="panel-card reveal">
          <div class="panel-card-header">
            <div class="panel-card-title">📚 Course Progress</div>
            <button class="panel-card-action" onclick="switchTab('courses')">View all →</button>
          </div>
          <div class="panel-card-body">
            <div class="prog-item">
