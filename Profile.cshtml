<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — My Profile</title>
<link rel="stylesheet" href="~/css/global.css"/>
<style>

/* ══════════════════════════════════════
   PROFILE HEADER
══════════════════════════════════════ */
.profile-header {
  padding-top: var(--nav-h);
  background: linear-gradient(160deg, var(--sky) 0%, #fff 70%);
  position: relative;
  overflow: hidden;
}
.profile-header::before {
  content: '';
  position: absolute;
  inset: 0;
                background-image: url('/image/ability4.png');
  background-size: 40%;
  background-repeat: no-repeat;
  background-position: right 5% center;
  opacity: .35;
  pointer-events: none;
}
.profile-header-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 48px 60px 0;
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  gap: 28px;
  flex-wrap: wrap;
}
.avatar-wrap {
  position: relative;
  flex-shrink: 0;
}
.avatar-circle {
  width: 100px; height: 100px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--lav), var(--peach));
  display: flex; align-items: center; justify-content: center;
  font-size: 2.8rem;
  border: 4px solid #fff;
  box-shadow: var(--shadow-md);
}
.avatar-edit {
  position: absolute;
  bottom: 2px; right: 2px;
  width: 28px; height: 28px;
  border-radius: 50%;
  background: var(--peach-d);
  border: 2px solid #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: .75rem;
  cursor: pointer;
  transition: background .2s;
}
.avatar-edit:hover { background: var(--peach-dd); }

.profile-info { flex: 1; padding-bottom: 4px; }
.profile-name {
  font-family: 'Playfair Display', serif;
  font-size: 1.9rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 4px;
  letter-spacing: -.02em;
}
.profile-email { font-size: .88rem; color: var(--ink-4); margin-bottom: 10px; }
.profile-badges { display: flex; gap: 8px; flex-wrap: wrap; }
.p-badge {
  padding: 4px 12px;
  border-radius: var(--radius-pill);
  font-size: .75rem;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  gap: 5px;
}

.profile-header-actions {
  display: flex;
  gap: 10px;
  padding-bottom: 8px;
  flex-shrink: 0;
  flex-wrap: wrap;
}

/* ══════════════════════════════════════
   TAB BAR
══════════════════════════════════════ */
.tab-bar {
  background: #fff;
  border-bottom: 1px solid rgba(0,0,0,.07);
  position: sticky;
  top: var(--nav-h);
  z-index: 50;
  box-shadow: 0 2px 12px rgba(0,0,0,.04);
}
.tab-bar-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 60px;
  display: flex;
  gap: 0;
}
.tab-btn {
  padding: 18px 24px;
  border: none;
  background: transparent;
  font-family: 'DM Sans', sans-serif;
  font-size: .88rem;
  font-weight: 600;
  color: var(--ink-4);
  cursor: pointer;
  position: relative;
  transition: color .2s;
  white-space: nowrap;
  display: flex;
  align-items: center;
  gap: 7px;
}
.tab-btn::after {
  content: '';
  position: absolute;
  bottom: 0; left: 0; right: 0;
  height: 3px;
  background: var(--peach-d);
  border-radius: 2px 2px 0 0;
  transform: scaleX(0);
  transition: transform .25s;
}
.tab-btn:hover { color: var(--ink); }
.tab-btn.active { color: var(--peach-d); }
.tab-btn.active::after { transform: scaleX(1); }
.tab-count {
  background: var(--peach);
  color: var(--ink);
  padding: 1px 7px;
  border-radius: var(--radius-pill);
  font-size: .7rem;
  font-weight: 800;
}

/* ══════════════════════════════════════
   PAGE BODY
══════════════════════════════════════ */
.profile-body {
  background: var(--off-white);
  min-height: 60vh;
}
.profile-body-inner {
  max-width: 1100px;
  margin: 0 auto;
  padding: 40px 60px 80px;
}

.tab-panel { display: none; }
.tab-panel.active { display: block; animation: fadeIn .25s ease; }
@@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }

/* ══════════════════════════════════════
   OVERVIEW TAB
══════════════════════════════════════ */
.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.overview-wide { grid-column: 1 / -1; }

.panel-card {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  overflow: hidden;
}
.panel-card-header {
  padding: 20px 24px 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}
.panel-card-title {
  font-weight: 700;
  font-size: .97rem;
  color: var(--ink);
  display: flex;
  align-items: center;
  gap: 8px;
}
.panel-card-action {
  font-size: .8rem;
  font-weight: 600;
  color: var(--peach-d);
  cursor: pointer;
  border: none;
  background: none;
  transition: color .2s;
}
.panel-card-action:hover { color: var(--peach-dd); }
.panel-card-body { padding: 0 24px 24px; }

/* Progress items */
.prog-item { margin-bottom: 16px; }
.prog-item:last-child { margin-bottom: 0; }
.prog-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 6px;
  gap: 10px;
}
.prog-name {
  font-size: .85rem;
  font-weight: 600;
  color: var(--ink);
  flex: 1;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.prog-pct { font-size: .78rem; font-weight: 700; color: var(--peach-d); }
.prog-bar { height: 7px; background: #EDF2F7; border-radius: 4px; overflow: hidden; }
.prog-fill {
  height: 100%;
  border-radius: 4px;
  background: linear-gradient(90deg, var(--mint-dd), var(--lav-d));
  transition: width .8s ease;
}
.prog-meta { font-size: .73rem; color: var(--ink-5); margin-top: 4px; }

/* Upcoming session item */
.session-item {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 12px 0;
  border-bottom: 1px solid rgba(0,0,0,.06);
}
.session-item:last-child { border-bottom: none; }
.session-dot {
  width: 44px; height: 44px;
  border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.3rem;
  flex-shrink: 0;
}
.session-info { flex: 1; }
.session-name { font-weight: 700; font-size: .88rem; color: var(--ink); }
.session-meta { font-size: .76rem; color: var(--ink-4); margin-top: 2px; }
.session-badge {
  padding: 3px 10px;
  border-radius: var(--radius-pill);
  font-size: .7rem;
  font-weight: 700;
  white-space: nowrap;
}

/* Achievements */
.achievements-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 10px;
}
.achievement {
  text-align: center;
  padding: 14px 8px;
  border-radius: 14px;
  background: var(--sky);
  transition: transform .2s;
  cursor: default;
}
.achievement:hover { transform: translateY(-3px); }
.achievement.locked { opacity: .35; filter: grayscale(1); }
.ach-icon { font-size: 1.8rem; margin-bottom: 6px; display: block; }
.ach-name { font-size: .68rem; font-weight: 700; color: var(--ink-2); line-height: 1.3; }

/* Stats row */
.stats-mini {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 2px;
  background: var(--sky);
  border-radius: var(--radius);
  overflow: hidden;
  margin-bottom: 20px;
}
.stat-mini {
  background: #fff;
  padding: 20px 16px;
  text-align: center;
}
.stat-mini-n {
  font-family: 'Playfair Display', serif;
  font-size: 1.6rem;
  font-weight: 900;
  color: var(--peach-d);
  display: block;
  line-height: 1;
}
.stat-mini-l { font-size: .74rem; color: var(--ink-4); margin-top: 5px; }

/* ══════════════════════════════════════
   MY COURSES TAB
══════════════════════════════════════ */
.courses-tabs {
  display: flex;
  gap: 8px;
  margin-bottom: 24px;
}
.sub-tab {
  padding: 8px 18px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: #fff;
  font-size: .82rem;
  font-weight: 600;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
}
.sub-tab:hover { border-color: var(--mint-d); }
.sub-tab.active {
  background: var(--peach);
  border-color: var(--peach-d);
  color: var(--ink);
}
.enrolled-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}
.enrolled-card {
  background: #fff;
  border-radius: var(--radius);
  overflow: hidden;
  border: 1.5px solid rgba(0,0,0,.07);
  transition: all .25s;
  cursor: pointer;
}
.enrolled-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: transparent; }
.ec-thumb {
  height: 110px;
  display: flex; align-items: center; justify-content: center;
  font-size: 2.8rem;
  position: relative;
}
.ec-body { padding: 16px; }
.ec-cat { font-size: .68rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--lav-d); margin-bottom: 4px; }
.ec-body h3 { font-weight: 700; font-size: .88rem; line-height: 1.4; margin-bottom: 10px; }
.ec-progress-bar { height: 5px; background: #EDF2F7; border-radius: 3px; overflow: hidden; margin-bottom: 6px; }
.ec-progress-fill { height: 100%; border-radius: 3px; background: linear-gradient(90deg, var(--mint-dd), var(--lav-d)); }
.ec-progress-label { font-size: .72rem; color: var(--ink-4); display: flex; justify-content: space-between; }
.ec-continue {
  display: block;
  width: 100%;
  margin-top: 12px;
  padding: 9px;
  border-radius: var(--radius-pill);
  border: none;
  background: var(--peach);
  color: var(--ink);
  font-weight: 700;
  font-size: .8rem;
  cursor: pointer;
  transition: all .2s;
}
.ec-continue:hover { background: var(--peach-d); color: #fff; }
.ec-completed { background: var(--sky); color: var(--mint-dd); }
.ec-completed:hover { background: var(--mint); color: #fff; }

/* ══════════════════════════════════════
   MY BOOKINGS TAB
══════════════════════════════════════ */
.bookings-list { display: flex; flex-direction: column; gap: 14px; }
.booking-item {
  background: #fff;
  border-radius: var(--radius);
  border: 1.5px solid rgba(0,0,0,.07);
  padding: 20px 24px;
  display: flex;
  align-items: center;
  gap: 18px;
  transition: all .2s;
}
.booking-item:hover { border-color: var(--mint-d); }
.booking-icon {
  width: 52px; height: 52px;
  border-radius: 16px;
  display: flex; align-items: center; justify-content: center;
  font-size: 1.6rem;
  flex-shrink: 0;
}
.booking-info { flex: 1; }
.booking-name { font-weight: 700; font-size: .95rem; color: var(--ink); margin-bottom: 3px; }
.booking-meta { font-size: .8rem; color: var(--ink-4); display: flex; flex-wrap: wrap; gap: 10px; }
.booking-status {
  padding: 4px 12px;
  border-radius: var(--radius-pill);
  font-size: .74rem;
  font-weight: 700;
  white-space: nowrap;
}
.booking-actions { display: flex; gap: 8px; flex-shrink: 0; }
.bk-btn {
  padding: 8px 14px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: transparent;
  font-size: .78rem;
  font-weight: 700;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
}
.bk-btn:hover { border-color: var(--ink-3); color: var(--ink); }
.bk-btn.danger:hover { border-color: #E53E3E; color: #E53E3E; }

/* ══════════════════════════════════════
   SETTINGS TAB
══════════════════════════════════════ */
.settings-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}
.settings-section {
  background: #fff;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 24px;
}
.settings-section h3 {
  font-weight: 700;
  font-size: .97rem;
  color: var(--ink);
  margin-bottom: 18px;
  display: flex;
  align-items: center;
  gap: 8px;
}
.toggle-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 0;
  border-bottom: 1px solid rgba(0,0,0,.06);
}
.toggle-row:last-child { border-bottom: none; }
.toggle-label { font-size: .88rem; color: var(--ink-2); }
.toggle-sub   { font-size: .76rem; color: var(--ink-4); margin-top: 2px; }
.toggle-switch {
  width: 44px; height: 24px;
  border-radius: 12px;
  background: #E2E8F0;
  position: relative;
  cursor: pointer;
  transition: background .25s;
  flex-shrink: 0;
  border: none;
}
.toggle-switch.on { background: var(--mint-dd); }
.toggle-switch::after {
  content: '';
  position: absolute;
  top: 3px; left: 3px;
  width: 18px; height: 18px;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 1px 4px rgba(0,0,0,.2);
  transition: left .25s;
}
.toggle-switch.on::after { left: 23px; }

.danger-zone {
  background: #FFF5F5;
  border: 1.5px solid #FED7D7;
  border-radius: var(--radius);
  padding: 24px;
}
.danger-zone h3 { color: #C53030; }
.danger-btn {
  padding: 10px 20px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #FEB2B2;
  background: transparent;
  color: #C53030;
  font-size: .84rem;
  font-weight: 700;
  cursor: pointer;
  transition: all .2s;
  margin-top: 8px;
}
.danger-btn:hover { background: #E53E3E; color: #fff; border-color: #E53E3E; }

/* Disability tags in settings */
.dis-tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 4px; }
.dis-tag {
  padding: 6px 14px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: var(--off-white);
  font-size: .8rem;
  font-weight: 600;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
}
.dis-tag:hover { border-color: var(--mint-d); }
.dis-tag.selected {
  background: var(--mint);
  border-color: var(--mint-dd);
  color: #00695C;
}

/* ══════════════════════════════════════
   RESPONSIVE
══════════════════════════════════════ */
@@media (max-width: 1100px) {
  .achievements-grid { grid-template-columns: repeat(4, 1fr); }
  .enrolled-grid { grid-template-columns: repeat(2, 1fr); }
  .stats-mini { grid-template-columns: repeat(2, 1fr); }
}
@@media (max-width: 900px) {
  .profile-header-inner { padding: 36px 24px 0; }
  .profile-body-inner   { padding: 28px 24px 60px; }
  .tab-bar-inner        { padding: 0 24px; overflow-x: auto; }
  .overview-grid        { grid-template-columns: 1fr; }
  .settings-grid        { grid-template-columns: 1fr; }
  .enrolled-grid        { grid-template-columns: 1fr 1fr; }
  .achievements-grid    { grid-template-columns: repeat(3, 1fr); }
}
@@media (max-width: 600px) {
  .enrolled-grid     { grid-template-columns: 1fr; }
  .achievements-grid { grid-template-columns: repeat(3, 1fr); }
  .booking-item      { flex-wrap: wrap; }
  .booking-actions   { width: 100%; }
  .profile-header-actions { width: 100%; }
  .stats-mini        { grid-template-columns: repeat(2, 1fr); }
}
</style>
</head>
<body>

<!-- ══════ NAV ══════ -->
