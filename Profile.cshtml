let activeCourseTab = 'inprogress'

function showCourseTab(status, btn) {
  activeCourseTab = status
  document.querySelectorAll('.sub-tab').forEach(b => b.classList.remove('active'))
  btn.classList.add('active')
  renderEnrolled()
}

function renderEnrolled() {
  const grid = document.getElementById('enrolledGrid')
  const catLabels = { adhd:'ADHD', autism:'Autism', deaf:'Deaf / Mute', blind:'Blind', down:'Down Syndrome', parent:'For Parents', teacher:'For Teachers', coach:'For Coaches' }

  const list = ENROLLED_COURSES.filter(c => c.status === activeCourseTab)

  if (!list.length) {
    grid.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px 20px;color:var(--ink-4)">
      <div style="font-size:2.5rem;margin-bottom:12px">${activeCourseTab === 'completed' ? '🎓' : '📚'}</div>
      <p>${activeCourseTab === 'completed' ? 'No completed courses yet.' : 'No courses in progress.'}</p>
      <a href="courses.html" style="color:var(--peach-d);font-weight:700;font-size:.88rem;text-decoration:none">Browse courses →</a>
    </div>`
    return
  }

  grid.innerHTML = list.map(c => `
    <div class="enrolled-card">
      <div class="ec-thumb" style="background:${c.color}">${c.emoji}</div>
      <div class="ec-body">
        <div class="ec-cat">${catLabels[c.category] || c.category}</div>
        <h3>${c.title}</h3>
        <div class="ec-progress-bar">
          <div class="ec-progress-fill" style="width:${c.progress}%"></div>
        </div>
        <div class="ec-progress-label">
          <span>${Math.round(c.progress * c.lessons / 100)} / ${c.lessons} lessons</span>
          <span>${c.progress}%</span>
        </div>
        <button class="ec-continue ${c.status === 'completed' ? 'ec-completed' : ''}"
          onclick="showToast('${c.status === 'completed' ? '🎓 Course completed!' : '▶ Resuming course…'}')">
          ${c.status === 'completed' ? '🎓 Review' : '▶ Continue'}
        </button>
      </div>
    </div>`).join('')
}

