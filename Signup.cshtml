<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>AbilityPlace — Sign Up</title>
<link rel="stylesheet" href="~/css/global.css"/>
<style>
body { background: var(--sky); }

.auth-page {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

/* ── SKY ── */
.auth-sky {
  width: 100%;
  height: 42vh;
  background: var(--sky);
  position: relative;
  overflow: hidden;
  flex-shrink: 0;
}
.auth-sky-birds {
  position: absolute;
  inset: 0;
            background-image: url('/image/ability4.png');
  background-size: 80%;
  background-repeat: no-repeat;
  background-position: center 20%;
}
.auth-wave {
  position: absolute;
  bottom: -1px; left: 0; right: 0;
  line-height: 0;
}

/* ── BODY ── */
.auth-body {
  background: #fff;
  flex: 1;
  position: relative;
  z-index: 1;
}

.auth-cols {
  max-width: 820px;
  margin: 0 auto;
  padding: 48px 40px 60px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 60px;
  align-items: start;
}

/* ── LEFT: FORM ── */
.auth-form-col h1 {
  font-family: 'Playfair Display', serif;
  font-size: 2.4rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 6px;
  letter-spacing: -.02em;
}
.auth-subtitle {
  font-size: .88rem;
  color: var(--ink-4);
  margin-bottom: 28px;
}

/* ── STEP INDICATOR ── */
.step-indicator {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 32px;
}
.step-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  flex: 1;
  position: relative;
}
.step-item:not(:last-child)::after {
  content: '';
  position: absolute;
  top: 16px;
  left: 50%;
  width: 100%;
  height: 2px;
  background: #E2E8F0;
  z-index: 0;
  transition: background .3s;
}
.step-item.done:not(:last-child)::after { background: var(--mint-d); }

.step-circle {
  width: 32px; height: 32px;
  border-radius: 50%;
  border: 2px solid #E2E8F0;
  background: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: .8rem;
  font-weight: 700;
  color: var(--ink-4);
  position: relative;
  z-index: 1;
  transition: all .3s;
}
.step-item.active .step-circle {
  background: var(--peach-d);
  border-color: var(--peach-d);
  color: #fff;
  box-shadow: 0 4px 12px rgba(255,138,101,.35);
}
.step-item.done .step-circle {
  background: var(--mint-d);
  border-color: var(--mint-d);
  color: #fff;
}
.step-label {
  font-size: .7rem;
  font-weight: 600;
  color: var(--ink-5);
  white-space: nowrap;
}
.step-item.active .step-label { color: var(--peach-d); }
.step-item.done .step-label   { color: var(--mint-dd); }

/* ── STEPS ── */
.step { display: none; }
.step.active { display: block; }

/* ── ROLE CHIPS ── */
.role-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin-bottom: 8px;
}
.role-chip {
  padding: 14px 16px;
  border-radius: var(--radius);
  border: 1.5px solid #E2E8F0;
  background: var(--off-white);
  cursor: pointer;
  transition: all .2s;
  text-align: left;
}
.role-chip:hover { border-color: var(--mint-d); }
.role-chip.selected {
  border-color: var(--peach-d);
  background: var(--peach);
}
.role-chip .rc-icon { font-size: 1.5rem; margin-bottom: 6px; display: block; }
.role-chip .rc-title { font-size: .88rem; font-weight: 700; color: var(--ink); }
.role-chip .rc-sub   { font-size: .75rem; color: var(--ink-4); margin-top: 2px; }

/* ── DISABILITY TAGS ── */
.section-label {
  font-size: .75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: .07em;
  color: var(--ink-4);
  margin-bottom: 10px;
  margin-top: 22px;
}
.disability-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: 8px;
}
.d-tag {
  padding: 7px 15px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: var(--off-white);
  font-size: .8rem;
  font-weight: 500;
  color: var(--ink-3);
  cursor: pointer;
  transition: all .2s;
}
.d-tag:hover { border-color: var(--mint-d); }
.d-tag.selected {
  background: var(--mint);
  border-color: var(--mint-dd);
  color: #00695C;
  font-weight: 700;
}

/* ── PASSWORD STRENGTH ── */
.pw-strength { margin-top: 8px; }
.pw-bar { height: 4px; background: #EDF2F7; border-radius: 2px; overflow: hidden; }
.pw-fill { height: 100%; width: 0%; border-radius: 2px; transition: width .3s, background .3s; }
.pw-label { font-size: .74rem; color: var(--ink-4); margin-top: 5px; }

/* ── STEP NAV BUTTONS ── */
.step-nav {
  display: flex;
  gap: 12px;
  margin-top: 28px;
}
.btn-back {
  padding: 12px 24px;
  border-radius: var(--radius-pill);
  border: 1.5px solid #E2E8F0;
  background: transparent;
  font-size: .9rem;
  font-weight: 600;
  color: var(--ink-3);
  transition: all .2s;
}
.btn-back:hover { border-color: var(--ink-3); color: var(--ink); }

/* ── CHECKBOX ── */
.check-row {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: .84rem;
  color: var(--ink-3);
  margin-bottom: 14px;
  line-height: 1.5;
}
.check-row input[type="checkbox"] {
  width: 17px; height: 17px;
  accent-color: var(--peach-d);
  flex-shrink: 0;
  margin-top: 2px;
}
.check-row a { color: var(--peach-d); font-weight: 600; }

/* ── RIGHT: WELCOME ── */
.auth-welcome-col {
  padding-top: 8px;
}
.auth-welcome-col h2 {
  font-family: 'Playfair Display', serif;
  font-size: 2.8rem;
  font-weight: 900;
  color: var(--ink);
  margin-bottom: 22px;
  letter-spacing: -.02em;
}
.auth-welcome-btns {
  display: flex;
  flex-direction: column;
  gap: 12px;
  max-width: 200px;
  margin-bottom: 28px;
}
.social-label { font-size: .78rem; color: var(--ink-4); margin-bottom: 12px; font-weight: 500; }
.social-row { display: flex; gap: 12px; }
.social-btn {
  width: 48px; height: 48px;
  border-radius: 50%;
  border: none;
  display: flex; align-items: center; justify-content: center;
  cursor: pointer;
  transition: transform .2s, box-shadow .2s;
  box-shadow: 0 2px 10px rgba(0,0,0,.12);
}
.social-btn:hover { transform: scale(1.1); box-shadow: 0 4px 16px rgba(0,0,0,.18); }
.social-btn.google   { background: #fff; border: 1.5px solid #E2E8F0; }
.social-btn.facebook { background: #1877F2; }
.social-btn.linkedin { background: #0A66C2; }

/* ── ERROR ── */
.error-msg { font-size: .78rem; color: #E53E3E; margin-top: 5px; display: none; }
.error-msg.show { display: block !important; }
.input-error { border-bottom-color: #FC8181 !important; }

/* ── RESPONSIVE ── */
@@media (max-width: 640px) {
  .auth-cols {
    grid-template-columns: 1fr;
    gap: 32px;
    padding: 32px 24px 48px;
  }
  .auth-welcome-col { display: none; }
  .auth-sky { height: 36vh; }
  .role-grid { grid-template-columns: 1fr; }
}
</style>
</head>
<body>

<div class="auth-page">

  <!-- SKY + BIRDS -->
  <div class="auth-sky">
    <div class="auth-sky-birds"></div>
    <div class="auth-wave">
      <svg viewBox="0 0 1440 80" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" style="width:100%;display:block">
        <path d="M0,40 C180,80 360,0 540,40 C720,80 900,0 1080,40 C1260,80 1380,20 1440,40 L1440,80 L0,80 Z" fill="rgba(255,255,255,.6)"/>
        <path d="M0,55 C200,20 400,75 600,50 C800,25 1000,70 1200,45 C1320,30 1400,60 1440,55 L1440,80 L0,80 Z" fill="#fff"/>
      </svg>
    </div>
  </div>

  <!-- CONTENT -->
  <div class="auth-body">
    <div class="auth-cols">

      <!-- LEFT: FORM -->
      <div class="auth-form-col">
        <h1>Sign up</h1>
        <p class="auth-subtitle">Join BridgeUp — it only takes a minute 🌱</p>

        <!-- Step indicator -->
        <div class="step-indicator">
          <div class="step-item active" id="si-1">
            <div class="step-circle">1</div>
            <div class="step-label">Account</div>
          </div>
          <div class="step-item" id="si-2">
            <div class="step-circle">2</div>
            <div class="step-label">About you</div>
          </div>
          <div class="step-item" id="si-3">
            <div class="step-circle">3</div>
            <div class="step-label">Preferences</div>
          </div>
        </div>

        <!-- ══ STEP 1: Account details ══ -->
        <div class="step active" id="step-1">
          <div class="form-group">
            <input class="form-input-line" type="text" id="name" placeholder="Full name" autocomplete="name"/>
            <div class="error-msg" id="name-err">Please enter your name.</div>
          </div>
          <div class="form-group">
            <input class="form-input-line" type="email" id="email" placeholder="Email address" autocomplete="email"/>
            <div class="error-msg" id="email-err">Please enter a valid email.</div>
          </div>
          <div class="form-group">
            <input class="form-input-line" type="password" id="password" placeholder="Password" oninput="checkStrength(this.value)"/>
            <div class="pw-strength">
              <div class="pw-bar"><div class="pw-fill" id="pw-fill"></div></div>
              <div class="pw-label" id="pw-label">Enter a password</div>
            </div>
            <div class="error-msg" id="pw-err">Password must be at least 8 characters.</div>
          </div>
          <div class="form-group">
            <input class="form-input-line" type="password" id="confirm" placeholder="Confirm password"/>
            <div class="error-msg" id="confirm-err">Passwords don't match.</div>
          </div>
          <div class="step-nav">
            <button class="btn-soft" style="flex:1" onclick="goStep(2)">Continue →</button>
          </div>
          <div style="text-align:center; margin-top:16px; font-size:.84rem; color:var(--ink-4)">
                            Already have an account? <a href="/Home/Signin" style="color:var(--peach-d);font-weight:700;">Sign in</a>
          </div>
        </div>

        <!-- ══ STEP 2: Role + disability ══ -->
        <div class="step" id="step-2">
          <div class="section-label">I am a…</div>
          <div class="role-grid" id="roleGrid">
            <div class="role-chip" onclick="selectRole(this,'disabled_minor')" data-role="disabled_minor">
              <span class="rc-icon">🧑‍🦽</span>
              <div class="rc-title">Person with Disability</div>
              <div class="rc-sub">Under 18</div>
            </div>
            <div class="role-chip" onclick="selectRole(this,'disabled_adult')" data-role="disabled_adult">
              <span class="rc-icon">🧑‍🦽</span>
              <div class="rc-title">Person with Disability</div>
              <div class="rc-sub">18 or older</div>
            </div>
            <div class="role-chip" onclick="selectRole(this,'parent')" data-role="parent">
              <span class="rc-icon">👨‍👩‍👧</span>
              <div class="rc-title">Parent / Guardian</div>
              <div class="rc-sub">Of a disabled person</div>
            </div>
            <div class="role-chip" onclick="selectRole(this,'teacher')" data-role="teacher">
              <span class="rc-icon">👩‍🏫</span>
              <div class="rc-title">Teacher</div>
              <div class="rc-sub">Special or inclusive ed</div>
            </div>
            <div class="role-chip" onclick="selectRole(this,'coach')" data-role="coach">
              <span class="rc-icon">🏃</span>
              <div class="rc-title">Coach / Therapist</div>
              <div class="rc-sub">Certified professional</div>
            </div>
          </div>
          <div class="error-msg" id="role-err">Please select a role.</div>

          <!-- Disability selector — only shown for disabled roles -->
          <div id="disability-section" style="display:none">
            <div class="section-label">My disability / condition</div>
            <div class="disability-tags" id="disabilityTags">
              <div class="d-tag" onclick="toggleTag(this)" data-val="adhd">🧠 ADHD</div>
              <div class="d-tag" onclick="toggleTag(this)" data-val="autism">🧩 Autism</div>
              <div class="d-tag" onclick="toggleTag(this)" data-val="down_syndrome">⬇️ Down Syndrome</div>
              <div class="d-tag" onclick="toggleTag(this)" data-val="deaf">🤟 Deaf</div>
              <div class="d-tag" onclick="toggleTag(this)" data-val="mute">🔇 Mute</div>
              <div class="d-tag" onclick="toggleTag(this)" data-val="blind">👁️ Blind / Low Vision</div>
            </div>
            <div style="font-size:.76rem;color:var(--ink-4)">Select all that apply. You can update this later.</div>
          </div>

          <div class="step-nav">
            <button class="btn-back" onclick="goStep(1)">← Back</button>
            <button class="btn-soft" style="flex:1" onclick="goStep(3)">Continue →</button>
          </div>
        </div>

        <!-- ══ STEP 3: Preferences ══ -->
        <div class="step" id="step-3">
          <div class="form-group">
            <label class="form-label">Country</label>
            <select class="form-input" id="country" style="border:none;border-bottom:1.5px solid #CBD5E0;border-radius:0;background:transparent;padding-left:0">
              <option value="">Select your country…</option>
              <option value="eg">🇪🇬 Egypt</option>
              <option value="sa">🇸🇦 Saudi Arabia</option>
              <option value="ae">🇦🇪 UAE</option>
              <option value="jo">🇯🇴 Jordan</option>
              <option value="lb">🇱🇧 Lebanon</option>
              <option value="other">🌍 Other</option>
            </select>
          </div>

          <div class="form-group">
            <label class="form-label">Preferred language</label>
            <select class="form-input" id="lang" style="border:none;border-bottom:1.5px solid #CBD5E0;border-radius:0;background:transparent;padding-left:0">
              <option value="en">🇬🇧 English</option>
              <option value="ar">🇪🇬 Arabic — عربي</option>
              <option value="fr">🇫🇷 French</option>
            </select>
          </div>

          <div style="margin-top:24px">
            <div class="check-row">
              <input type="checkbox" id="tos"/>
              <label for="tos">I agree to the <a href="#">Terms of Service</a> and <a href="#">Privacy Policy</a></label>
            </div>
            <div class="check-row">
              <input type="checkbox" id="newsletter" checked/>
              <label for="newsletter">Send me updates about new courses and features</label>
            </div>
          </div>
          <div class="error-msg" id="tos-err">Please accept the Terms of Service to continue.</div>

          <div class="step-nav">
            <button class="btn-back" onclick="goStep(2)">← Back</button>
            <button class="btn-soft" style="flex:1" onclick="handleSignUp()">Create account 🎉</button>
          </div>
        </div>

      </div>

      <!-- RIGHT: WELCOME -->
      <div class="auth-welcome-col">
        <h2>Welcome</h2>
        <div class="auth-welcome-btns">
                        <button class="btn-soft" onclick="window.location='/Home/Signin'" style="width:100%">Sign in</button>
                        <button class="btn-soft" onclick="window.location='/Home/Signup'" style="width:100%">Sign up</button>
        </div>
        <div class="social-label">Or continue with</div>
        <div class="social-row">
          <button class="social-btn google" onclick="showToast('Google sign-up coming soon!')">
            <svg width="20" height="20" viewBox="0 0 48 48">
              <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"/>
              <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"/>
              <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"/>
              <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"/>
            </svg>
          </button>
          <button class="social-btn facebook" onclick="showToast('Facebook sign-up coming soon!')">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="white">
              <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.41c0-3.025 1.792-4.697 4.533-4.697 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.93-1.956 1.886v2.288h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
            </svg>
          </button>
          <button class="social-btn linkedin" onclick="showToast('LinkedIn sign-up coming soon!')">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="white">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </button>
        </div>
        <div style="margin-top:24px; font-size:.84rem; color:var(--ink-4);">
          Already have an account?
                        <a href="/Home/Signin" style="color:var(--peach-d);font-weight:700;">Sign in →</a>
        </div>

        <!-- What you get -->
        <div style="margin-top:36px; padding:20px; background:var(--sky); border-radius:var(--radius);">
          <div style="font-weight:700; font-size:.88rem; margin-bottom:12px; color:var(--ink)">What you get 🎁</div>
          <div style="display:flex;flex-direction:column;gap:8px;">
            <div style="font-size:.82rem;color:var(--ink-3);display:flex;gap:8px;align-items:center"><span>✅</span> Access to 120+ free courses</div>
            <div style="font-size:.82rem;color:var(--ink-3);display:flex;gap:8px;align-items:center"><span>✅</span> Book therapy sessions</div>
            <div style="font-size:.82rem;color:var(--ink-3);display:flex;gap:8px;align-items:center"><span>✅</span> Sign language lessons</div>
            <div style="font-size:.82rem;color:var(--ink-3);display:flex;gap:8px;align-items:center"><span>✅</span> AI-powered assistant</div>
            <div style="font-size:.82rem;color:var(--ink-3);display:flex;gap:8px;align-items:center"><span>✅</span> Find centers near you</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<script>
let currentStep = 1
let selectedRole = null
let selectedDisabilities = []

// ── STEP NAVIGATION ──
function goStep(n) {
  // Only validate when moving forward
  if (n > currentStep && !validate(currentStep)) return

  // Hide current step
  document.getElementById('step-' + currentStep).classList.remove('active')

  // Update step indicator
  for (let i = 1; i <= 3; i++) {
    const si = document.getElementById('si-' + i)
    si.classList.remove('active', 'done')
    if (i < n)  si.classList.add('done')
    if (i === n) si.classList.add('active')
  }

  // Show new step
  document.getElementById('step-' + n).classList.add('active')
  currentStep = n

  // Scroll to top of form on mobile
  document.querySelector('.auth-form-col').scrollIntoView({ behavior: 'smooth', block: 'start' })
}

// ── VALIDATION ──
function validate(step) {
  if (step === 1) {
    const name    = document.getElementById('name').value.trim()
    const email   = document.getElementById('email').value.trim()
    const pw      = document.getElementById('password').value
    const confirm = document.getElementById('confirm').value
    let ok = true

    clearErrors()

    if (!name) {
      show('name-err'); document.getElementById('name').classList.add('input-error'); ok = false
    }
    if (!email || !email.includes('@@')) {
      show('email-err'); document.getElementById('email').classList.add('input-error'); ok = false
    }
    if (pw.length < 8) {
      show('pw-err'); ok = false
    }
    if (pw !== confirm) {
      show('confirm-err'); ok = false
    }
    return ok
  }

  if (step === 2) {
    if (!selectedRole) {
      show('role-err'); return false
    }
    return true
  }

  return true
}

function clearErrors() {
  document.querySelectorAll('.error-msg').forEach(e => e.classList.remove('show'))
  document.querySelectorAll('.input-error').forEach(e => e.classList.remove('input-error'))
}

function show(id) {
  const el = document.getElementById(id)
  if (el) el.classList.add('show')
}

// ── ROLE SELECTION ──
function selectRole(el, role) {
  document.querySelectorAll('.role-chip').forEach(c => c.classList.remove('selected'))
  el.classList.add('selected')
  selectedRole = role

  // Show disability section for disabled users
  const showDisability = role === 'disabled_minor' || role === 'disabled_adult'
  document.getElementById('disability-section').style.display = showDisability ? 'block' : 'none'
}

// ── DISABILITY TAGS ──
function toggleTag(el) {
  el.classList.toggle('selected')
  const val = el.dataset.val
  if (el.classList.contains('selected')) {
    selectedDisabilities.push(val)
  } else {
    selectedDisabilities = selectedDisabilities.filter(d => d !== val)
  }
}

// ── PASSWORD STRENGTH ──
function checkStrength(val) {
  const fill  = document.getElementById('pw-fill')
  const label = document.getElementById('pw-label')
  if (!val) { fill.style.width = '0%'; label.textContent = 'Enter a password'; return }

  let score = 0
  if (val.length >= 8)          score++
  if (/[A-Z]/.test(val))        score++
  if (/[0-9]/.test(val))        score++
  if (/[^a-zA-Z0-9]/.test(val)) score++

  const colors = ['#FC8181','#F6AD55','#68D391','#48BB78']
  const labels = ['Weak','Fair','Good','Strong 💪']
  fill.style.width    = (score * 25) + '%'
  fill.style.background = colors[score - 1] || colors[0]
  label.textContent   = labels[score - 1] || 'Weak'
}

// ── SIGN UP SUBMIT ──
async function handleSignUp() {
  if (!document.getElementById('tos').checked) {
    show('tos-err'); return
  }

  const userData = {
    name:         document.getElementById('name').value.trim(),
    email:        document.getElementById('email').value.trim(),
    password:     document.getElementById('password').value,
    role:         selectedRole,
    disabilities: selectedDisabilities,
    country:      document.getElementById('country').value,
    language:     document.getElementById('lang').value,
