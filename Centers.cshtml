const SERVICE_LABELS = {
  diagnosis:  '🔬 Diagnosis',
  speech:     '🗣️ Speech Therapy',
  sensory:    '🌈 Sensory Therapy',
  behavioral: '🧠 Behavioral',
  training:   '🏃 Training',
  deaf:       '🤟 Deaf Support',
  blind:      '👁️ Blind Support',
}

// ══════════════════════════════════════
// STATE
// ══════════════════════════════════════
let allCenters     = [...CENTERS_DATA]
let activeFilter   = ''
let searchQuery    = ''
let sortMode       = 'rating'
let selectedCenter = null

// ══════════════════════════════════════
// NAV
// ══════════════════════════════════════
window.addEventListener('scroll', () => {
  document.getElementById('navbar').classList.toggle('scrolled', window.scrollY > 10)
})
function toggleMenu() {
  document.getElementById('mobileMenu').classList.toggle('open')
}
document.querySelectorAll('.mobile-menu-link').forEach(l => {
  l.addEventListener('click', () => document.getElementById('mobileMenu').classList.remove('open'))
})

// ══════════════════════════════════════
// FILTER / SEARCH / SORT
// ══════════════════════════════════════
function setFilter(filter, btn) {
  activeFilter = filter
  document.querySelectorAll('.fchip').forEach(c => c.classList.remove('active'))
  btn.classList.add('active')
  renderCenters()
}

let searchTimer = null
function handleSearch(val) {
  clearTimeout(searchTimer)
  searchTimer = setTimeout(() => {
    searchQuery = val.trim().toLowerCase()
    renderCenters()
  }, 220)
}

function handleSort(val) {
  sortMode = val
  renderCenters()
}

// ══════════════════════════════════════
// RENDER
// ══════════════════════════════════════
function renderCenters() {
  const list      = document.getElementById('centersList')
  const countEl   = document.getElementById('resultsCount')
  const listCount = document.getElementById('listCount')

  let results = [...allCenters]

  // Filter by service
  if (activeFilter) {
    results = results.filter(c => c.services.includes(activeFilter))
  }

  // Search by name, city, address
  if (searchQuery) {
    results = results.filter(c =>
      c.name.toLowerCase().includes(searchQuery) ||
      c.city.toLowerCase().includes(searchQuery) ||
      c.address.toLowerCase().includes(searchQuery) ||
      c.description.toLowerCase().includes(searchQuery)
    )
  }

  // Sort
  if (sortMode === 'rating') results.sort((a, b) => b.rating - a.rating)
  if (sortMode === 'name')   results.sort((a, b) => a.name.localeCompare(b.name))
  if (sortMode === 'newest') results.sort((a, b) => new Date(b.created_at) - new Date(a.created_at))

  const n = results.length
  countEl.textContent  = `${n} center${n !== 1 ? 's' : ''}`
  listCount.textContent = `Showing ${n} center${n !== 1 ? 's' : ''}`

  if (!n) {
    list.innerHTML = `
      <div class="empty-state">
        <div class="empty-icon">🏥</div>
        <h3>No centers found</h3>
        <p>Try a different search or filter.</p>
      </div>`
    return
  }

  list.innerHTML = results.map(c => {
    const isSelected = selectedCenter && selectedCenter.id === c.id
    const verifiedHtml = c.is_verified
      ? `<span class="verified-badge">✓ Verified</span>` : ''
    const openHtml = `<span class="center-open ${c.is_open ? 'open' : 'closed'}">${c.is_open ? '● Open now' : '● Closed'}</span>`
    const starsHtml = '★'.repeat(Math.round(c.rating)) + '☆'.repeat(5 - Math.round(c.rating))

    return `
      <div class="center-card reveal ${isSelected ? 'selected' : ''}" id="card-${c.id}" onclick="selectCenter('${c.id}')">
        <div class="center-icon-wrap" style="background:${c.icon_bg}">${c.icon_emoji}</div>
        <div class="center-body">
          <div class="center-top">
            <div>
              <span class="center-name">${c.name}</span>
              ${verifiedHtml}
            </div>
            <span class="center-rating" title="${c.rating} stars">
              <span style="color:var(--peach-d)">${starsHtml}</span> ${c.rating}
            </span>
          </div>
          <div class="center-address">📍 ${c.address}, ${c.city}</div>
          <p class="center-desc">${c.description}</p>
          <div class="center-services">
            ${c.services.map(s => `<span class="service-tag">${SERVICE_LABELS[s] || s}</span>`).join('')}
          </div>
          <div class="center-footer">
            <div class="center-meta">
              ${openHtml}
              <span>📞 ${c.phone}</span>
            </div>
            <div class="center-btns">
              <button class="cbtn outline" onclick="event.stopPropagation(); callCenter('${c.phone}')">Call</button>
              <button class="cbtn filled" onclick="event.stopPropagation(); bookCenterVisit('${c.id}', '${c.name.replace(/'/g,"\\'")}')">Book Visit</button>
            </div>
          </div>
        </div>
      </div>`
  }).join('')

  // Scroll reveal
  list.querySelectorAll('.reveal').forEach((el, i) => {
    el.style.transitionDelay = (i * 60) + 'ms'
    revealObserver.observe(el)
  })
}

// ══════════════════════════════════════
// CENTER SELECTION (links to map)
// ══════════════════════════════════════
function selectCenter(id) {
  selectedCenter = CENTERS_DATA.find(c => c.id === id)

  // Update card highlight
  document.querySelectorAll('.center-card').forEach(c => c.classList.remove('selected'))
  document.getElementById('card-' + id).classList.add('selected')

  // Update map info panel
  document.getElementById('mciName').textContent    = selectedCenter.name
  document.getElementById('mciAddress').textContent = `${selectedCenter.address}, ${selectedCenter.city}`
  document.getElementById('mapCenterInfo').classList.add('show')

  // TODO: pan map to center.lat, center.lng
  // map.panTo({ lat: selectedCenter.lat, lng: selectedCenter.lng })
  // map.setZoom(15)
  showToast(`📍 ${selectedCenter.name} selected`)
}

function getDirections() {
  if (!selectedCenter) return
  // Opens Google Maps directions
  const url = `https://www.google.com/maps/dir/?api=1&destination=${selectedCenter.lat},${selectedCenter.lng}`
  window.open(url, '_blank')
}

function bookCenterVisit(id, name) {
  // TODO: pre-fill bookings page with this center selected
  // window.location = `bookings.html?center=${id}`
  showToast(`📅 Opening bookings for ${name}…`)
  setTimeout(() => window.location.href = 'bookings.html', 1000)
}

function bookCenter() {
  if (selectedCenter) bookCenterVisit(selectedCenter.id, selectedCenter.name)
}

function callCenter(phone) {
  window.location.href = `tel:${phone}`
}

// ══════════════════════════════════════
// HELPERS
// ══════════════════════════════════════
const revealObserver = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (!entry.isIntersecting) return
    entry.target.classList.add('visible')
  })
}, { threshold: 0.06 })

function showToast(msg) {
  const t = document.getElementById('toast')
  t.textContent = msg
  t.classList.add('show')
  setTimeout(() => t.classList.remove('show'), 2800)
}

// ══════════════════════════════════════
// INIT
// ══════════════════════════════════════
renderCenters()
</script>
